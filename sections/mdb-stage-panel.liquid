{%- render 'section-spacing-collapsing' -%}

{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
CSS

Mealtime Development Box — stage panel. Per build-brief Section 6.4 ("Inside the box"),
restructured per the page-template architecture in CLAUDE.md (Bundle Box →
/pages/mealtime-development-box) and standing decision #8 (alternating panels).

ONE section file, expected to be added 4 times to /pages/mealtime-development-box
(one per stage 1–4). Each panel shows what's in the box for that developmental stage,
with WHY-driven product copy.

Layout per panel:
- Stage pill (e.g. "Stage 1 · 6–12 months")
- H2 heading + body
- "Signs your child is ready" — 4 bullets (2×2)
- 3 product cards, each with: image, name, RRP, 2-bullet WHY description
- "View this stage's full guide →" CTA → /pages/mealtime-development-box-stage-N-...
- Optional next-stage teaser

Anchor contract: emits id="{stage_id}" on the <mdb-stage-panel> custom element.
Default IDs match the build flow: stage-1 / stage-2 / stage-3 / stage-4.

Standing decisions applied:
- Per-card product copy (not from a collection) so the WHY description per stage
  can differ for the same product across stages — matches handoff doc structure
- Defer add-to-bag — product cards link to PDP only via per-card url field
- Alternating panel backgrounds
- No reveal-on-scroll attributes (Impact's global opacity:0 trap)
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --mdb-panel-bg: {{ section.settings.panel_bg.rgb }};
    --mdb-panel-padding-d: {{ section.settings.padding_d }}px;
    --mdb-panel-padding-m: {{ section.settings.padding_m }}px;
    --mdb-panel-pill-color: {{ section.settings.pill_color.rgb }};
    --mdb-panel-heading-color: {{ section.settings.heading_color.rgb }};
    --mdb-panel-heading-size: {{ section.settings.heading_size_m }}px;
    --mdb-panel-body-size: {{ section.settings.body_size }}px;
    --mdb-panel-sign-size: {{ section.settings.sign_size }}px;
    --mdb-panel-img-size-m: {{ section.settings.img_size_m }}px;
    --mdb-panel-img-size-d: {{ section.settings.img_size_d }}px;
    --mdb-panel-name-size: {{ section.settings.name_size }}px;
    --mdb-panel-desc-size: {{ section.settings.desc_size }}px;
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --mdb-panel-heading-size: {{ section.settings.heading_size_d }}px;
    }
  }

  /* Wrapper */
  #shopify-section-{{ section.id }} .mdb-panel {
    display: block;
    background-color: rgb(var(--mdb-panel-bg));
    padding: var(--mdb-panel-padding-m) var(--container-gutter);
    scroll-margin-top: var(--header-height, 0);
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .mdb-panel {
      padding: var(--mdb-panel-padding-d) var(--container-gutter);
    }
  }

  #shopify-section-{{ section.id }} .mdb-panel__inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
  }

  /* Stage pill */
  #shopify-section-{{ section.id }} .mdb-panel__pill {
    display: inline-block;
    padding: var(--spacing-1-5) var(--spacing-3);
    background: rgb(var(--mdb-panel-pill-color));
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: var(--rounded-full);
    margin-bottom: var(--spacing-4);
  }

  /* Heading */
  #shopify-section-{{ section.id }} .mdb-panel__heading {
    margin: 0 0 var(--spacing-3);
    font-family: var(--heading-font-family);
    font-weight: var(--heading-font-weight);
    font-size: var(--mdb-panel-heading-size);
    line-height: 1.2;
    color: rgb(var(--mdb-panel-heading-color));
  }

  /* Body */
  #shopify-section-{{ section.id }} .mdb-panel__body {
    margin: 0 0 var(--spacing-8);
    font-size: var(--mdb-panel-body-size);
    line-height: 1.6;
    color: rgb(var(--text-primary) / 0.85);
    max-width: 65ch;
  }

  /* Signs block */
  #shopify-section-{{ section.id }} .mdb-panel__signs-label {
    margin: 0 0 var(--spacing-3);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(var(--mdb-panel-heading-color));
  }

  #shopify-section-{{ section.id }} .mdb-panel__signs {
    list-style: none;
    margin: 0 0 var(--spacing-10);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-3);
  }

  #shopify-section-{{ section.id }} .mdb-panel__sign {
    padding: var(--spacing-4);
    background: rgb(var(--doddl-color-bg));
    border-left: 3px solid rgb(var(--mdb-panel-pill-color));
    border-radius: 0 var(--rounded) var(--rounded) 0;
    font-size: var(--mdb-panel-sign-size);
    line-height: 1.4;
  }

  /* Inside-the-box label */
  #shopify-section-{{ section.id }} .mdb-panel__inside-label {
    margin: 0 0 var(--spacing-5);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--mdb-panel-heading-color));
  }

  /* Product card grid */
  #shopify-section-{{ section.id }} .mdb-panel__products {
    list-style: none;
    margin: 0 0 var(--spacing-8);
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--spacing-4);
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .mdb-panel__products {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-6);
    }
  }

  #shopify-section-{{ section.id }} .mdb-panel__product {
    display: flex;
    flex-direction: row;
    gap: var(--spacing-4);
    padding: var(--spacing-4);
    background: rgb(var(--background-primary));
    border-radius: var(--rounded);
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .mdb-panel__product {
      flex-direction: column;
      gap: var(--spacing-3);
    }
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-image {
    flex-shrink: 0;
    width: var(--mdb-panel-img-size-m);
    height: var(--mdb-panel-img-size-m);
    overflow: hidden;
    background: rgb(var(--doddl-color-bg));
    border-radius: var(--rounded-sm);
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .mdb-panel__product-image {
      width: 100%;
      height: var(--mdb-panel-img-size-d);
    }
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--text-primary) / 0.4);
    font-size: 10px;
    text-align: center;
    padding: var(--spacing-2);
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-name {
    margin: 0;
    font-size: var(--mdb-panel-name-size);
    font-weight: 700;
    line-height: 1.3;
    color: rgb(var(--mdb-panel-heading-color));
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-name a {
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-name a:hover,
  #shopify-section-{{ section.id }} .mdb-panel__product-name a:focus-visible {
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-rrp {
    font-size: var(--text-xs);
    font-weight: 600;
    color: rgb(var(--text-primary) / 0.6);
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-bullet {
    position: relative;
    padding-left: var(--spacing-4);
    font-size: var(--mdb-panel-desc-size);
    line-height: 1.5;
    color: rgb(var(--text-primary) / 0.8);
  }

  #shopify-section-{{ section.id }} .mdb-panel__product-bullet::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: rgb(var(--mdb-panel-pill-color));
    font-weight: 700;
  }

  /* CTA */
  #shopify-section-{{ section.id }} .mdb-panel__cta-row {
    margin: 0 0 var(--spacing-8);
  }

  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} .mdb-panel__cta-row .button {
      width: 100%;
    }
  }

  /* Next-stage teaser */
  #shopify-section-{{ section.id }} .mdb-panel__next {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding: var(--spacing-5);
    background: rgb(var(--doddl-color-bg));
    border-radius: var(--rounded);
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .mdb-panel__next-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(var(--mdb-panel-pill-color));
    color: white;
    border-radius: 50%;
    font-size: 20px;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .mdb-panel__next-content {
    flex: 1 1 200px;
  }

  #shopify-section-{{ section.id }} .mdb-panel__next-label {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--text-primary) / 0.55);
  }

  #shopify-section-{{ section.id }} .mdb-panel__next-heading {
    margin: 2px 0 var(--spacing-1);
    font-weight: 700;
    color: rgb(var(--mdb-panel-heading-color));
  }

  #shopify-section-{{ section.id }} .mdb-panel__next-body {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.5;
    color: rgb(var(--text-primary) / 0.7);
  }

  #shopify-section-{{ section.id }} .mdb-panel__next-cta {
    flex: 0 0 auto;
  }
</style>

