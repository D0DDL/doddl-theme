{%- endcomment -%}

{%- assign stage_number = section.settings.stage_number | times: 1 -%}
{%- assign collection_handle = section.settings.collection -%}
{%- assign stage_collection = collections[collection_handle] -%}

<div {% render 'section-properties' %}>
  <stage-panel class="stage-panel" id="stage-panel-{{ stage_number }}">
    <div class="stage-panel__inner">
      {%- if section.settings.pill_text != blank -%}
        <span class="stage-panel__pill">{{ section.settings.pill_text | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="stage-panel__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="stage-panel__body">{{ section.settings.body | escape | newline_to_br }}</p>
      {%- endif -%}

      {%- comment -%} Milestones 2x2 grid {%- endcomment -%}
      {%- assign has_milestone = false -%}
      {%- for m in (1..4) -%}
        {%- assign m_key = 'm' | append: m -%}
        {%- if section.settings[m_key] != blank -%}{%- assign has_milestone = true -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_milestone -%}
        <ul class="stage-panel__milestones" role="list">
          {%- for m in (1..4) -%}
            {%- assign m_key = 'm' | append: m -%}
            {%- assign m_value = section.settings[m_key] -%}
            {%- if m_value != blank -%}
              <li class="stage-panel__milestone">{{ m_value | escape }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- comment -%} Shop CTA row {%- endcomment -%}
      {%- if section.settings.cta_label != blank -%}
        <div class="stage-panel__shop-row">
          <span class="stage-panel__shop-label">Products for this stage</span>
          <a
            href="{{ section.settings.cta_url | default: stage_collection.url | default: '#' }}"
            class="button button--xl"
          >
            {{- section.settings.cta_label | escape -}}
          </a>
        </div>
      {%- endif -%}

      {%- comment -%} Product grid {%- endcomment -%}
      {%- if stage_collection != blank and stage_collection.products.size > 0 -%}
        <div class="stage-panel__products" role="list">
          {%- for product in stage_collection.products limit: 5 -%}
            {%- assign is_best = false -%}
            {%- if product.tags contains 'best-value' -%}{%- assign is_best = true -%}{%- endif -%}
            <div class="stage-panel__product{% if is_best %} is-best-value{% endif %}" role="listitem">
              <span class="stage-panel__best-badge" aria-hidden="true">Best value</span>
              <a href="{{ product.url }}" class="stage-panel__product-link">
                <div class="stage-panel__product-image">
                  {%- if product.featured_image != blank -%}
                    {{- product.featured_image
                        | image_url: width: product.featured_image.width
                        | image_tag:
                            loading: 'lazy',
                            sizes: '(max-width: 999px) 60vw, 18vw',
                            widths: '200,300,400,500,600,800',
                            class: 'stage-panel__product-img' -}}
                  {%- else -%}
                    {{- 'product-1' | placeholder_svg_tag: 'stage-panel__product-img' -}}
                  {%- endif -%}
                </div>
                <p class="stage-panel__product-name">{{ product.title | escape }}</p>
                <p class="stage-panel__product-price">{{ product.price | money }}</p>
              </a>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="stage-panel__placeholder">
          {%- if collection_handle != blank -%}
            <p>
              Products will appear here once the
              <code>{{ collection_handle | escape }}</code>
              collection is created in Shopify.
            </p>
          {%- else -%}
            <p>Products will appear here once a collection is selected in the section settings.</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Expert quote {%- endcomment -%}
      {%- if section.settings.expert_quote != blank -%}
        <blockquote class="stage-panel__expert">
          <p class="stage-panel__quote">{{ section.settings.expert_quote | escape | newline_to_br }}</p>
          {%- if section.settings.expert_name != blank or section.settings.expert_role != blank -%}
            <div class="stage-panel__quote-attr">
              {%- if section.settings.expert_name != blank -%}
                <cite class="stage-panel__expert-name">{{ section.settings.expert_name | escape }}</cite>
              {%- endif -%}
              {%- if section.settings.expert_role != blank -%}
                <span class="stage-panel__expert-role">{{ section.settings.expert_role | escape }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if section.settings.trust_1 != blank or section.settings.trust_2 != blank -%}
            <ul class="stage-panel__trust-list" role="list">
              {%- if section.settings.trust_1 != blank -%}
                <li class="stage-panel__trust-pill">{{ section.settings.trust_1 | escape }}</li>
              {%- endif -%}
              {%- if section.settings.trust_2 != blank -%}
                <li class="stage-panel__trust-pill">{{ section.settings.trust_2 | escape }}</li>
              {%- endif -%}
            </ul>
          {%- endif -%}
        </blockquote>
      {%- endif -%}

      {%- comment -%} Next-stage teaser — hidden when no heading/body set (so stage 4 can omit) {%- endcomment -%}
      {%- if section.settings.next_heading != blank or section.settings.next_body != blank -%}
        <div class="stage-panel__next">
          {%- if section.settings.next_icon != blank -%}
            <span class="stage-panel__next-icon" aria-hidden="true">{{ section.settings.next_icon | escape }}</span>
          {%- endif -%}
          <div class="stage-panel__next-content">
            {%- if section.settings.next_label != blank -%}
              <p class="stage-panel__next-label">{{ section.settings.next_label | escape }}</p>
            {%- endif -%}
            {%- if section.settings.next_heading != blank -%}
              <p class="stage-panel__next-heading">{{ section.settings.next_heading | escape }}</p>
            {%- endif -%}
            {%- if section.settings.next_body != blank -%}
              <p class="stage-panel__next-body">{{ section.settings.next_body | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
          {%- if section.settings.next_cta != blank and section.settings.next_url != blank -%}
            <a href="{{ section.settings.next_url }}" class="button button--lg stage-panel__next-cta">
              {{- section.settings.next_cta | escape -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </stage-panel>
</div>

{% schema %}
{
  "name": "Shop by stage — panel",
  "class": "shopify-section--stage-panel",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    { "type": "header", "content": "Stage identity" },
    { "type": "select", "id": "stage_number", "label": "Stage number",
      "info": "Determines the anchor ID emitted by this instance (#stage-panel-N). Each instance on the page should have a unique number 0–4 to match the Shop by stage selector.",
      "options": [
        { "value": "0", "label": "0 — Preparing (0–6 months)" },
        { "value": "1", "label": "1 — First Foods (6–12 months)" },
        { "value": "2", "label": "2 — Building Control (12–18 months)" },
        { "value": "3", "label": "3 — Growing Skills (18 months – 3 years)" },
        { "value": "4", "label": "4 — Eating Independently (3–5 years)" }
      ],
      "default": "0"
    },
    { "type": "text", "id": "pill_text", "label": "Stage pill text", "default": "Stage 0 · 0–6 months" },
    { "type": "color", "id": "pill_color", "label": "Pill colour", "info": "Also tints milestones, expert-quote accent, best-value border, and the next-stage teaser icon. Defaults to doddl aqua.", "default": "#30BEAA" },

    { "type": "header", "content": "Heading and body" },
    { "type": "text", "id": "heading", "label": "Headline (H2)", "default": "First foods, first wins" },
    { "type": "range", "id": "heading_size_d", "label": "Heading size — desktop", "min": 20, "max": 40, "step": 2, "unit": "px", "default": 28 },
    { "type": "range", "id": "heading_size_m", "label": "Heading size — mobile", "min": 18, "max": 34, "step": 2, "unit": "px", "default": 24 },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#3D157D" },
    { "type": "textarea", "id": "body", "label": "Body copy", "info": "2–3 sentences." },
    { "type": "range", "id": "body_size", "label": "Body size", "min": 13, "max": 19, "step": 1, "unit": "px", "default": 15 },

    { "type": "header", "content": "Milestones (2×2 grid)" },
    { "type": "text", "id": "m1", "label": "Milestone 1" },
    { "type": "text", "id": "m2", "label": "Milestone 2" },
    { "type": "text", "id": "m3", "label": "Milestone 3" },
    { "type": "text", "id": "m4", "label": "Milestone 4" },
    { "type": "range", "id": "milestone_size", "label": "Milestone text size", "min": 10, "max": 15, "step": 1, "unit": "px", "default": 12 },

    { "type": "header", "content": "Shop CTA and product grid" },
    { "type": "text", "id": "cta_label", "label": "Shop CTA label", "default": "Shop this stage →" },
    { "type": "url", "id": "cta_url", "label": "Shop CTA URL", "info": "Leave blank to default to the collection's URL." },
    { "type": "collection", "id": "collection", "label": "Product collection", "info": "Pulls 5 products. Tag one product 'best-value' to highlight it with an aqua border and badge." },
    { "type": "range", "id": "product_img_size", "label": "Product image size", "min": 120, "max": 280, "step": 20, "unit": "px", "default": 200 },
    { "type": "range", "id": "product_name_size", "label": "Product name size", "min": 11, "max": 16, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "product_price_size", "label": "Product price size", "min": 12, "max": 18, "step": 1, "unit": "px", "default": 14 },

    { "type": "header", "content": "Expert quote" },
    { "type": "textarea", "id": "expert_quote", "label": "Quote text" },
    { "type": "range", "id": "quote_size", "label": "Quote size", "min": 12, "max": 18, "step": 1, "unit": "px", "default": 14 },
    { "type": "text", "id": "expert_name", "label": "Expert name" },
    { "type": "text", "id": "expert_role", "label": "Expert role / credentials" },
    { "type": "text", "id": "trust_1", "label": "Trust label 1", "default": "OT UK" },
    { "type": "text", "id": "trust_2", "label": "Trust label 2", "default": "NCT" },

    { "type": "header", "content": "Next-stage teaser" },
    { "type": "paragraph", "content": "Leave Next heading and Next body blank to hide the entire teaser (use this on Stage 4 — the last stage)." },
    { "type": "text", "id": "next_icon", "label": "Icon (emoji or short text)", "default": "→" },
    { "type": "text", "id": "next_label", "label": "Eyebrow label", "default": "Coming up" },
