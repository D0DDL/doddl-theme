{%- render 'section-spacing-collapsing' -%}

{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
CSS

Shop by Stage — panel. Per build-brief Section 4.3.
ONE section file, expected to be added 5 times to /pages/shop-by-stage (one per stage 0–4).
Each instance carries a stage_number setting (0–4) which determines the anchor ID
("stage-panel-N") that the stage-selector links to.

Layout per panel:
- Coloured stage pill
- H2 headline + body copy
- 4 milestones in 2x2 grid
- "Products for this stage" label + Shop CTA, then 5-product grid (mobile horizontal scroll)
- Best-value highlight: products tagged 'best-value' get aqua border + badge.
  Detection is server-side via {% if product.tags contains 'best-value' %} — no JS needed.
- Expert quote block with 2 trust labels
- Next-stage teaser card (hidden when next_heading and next_body are both blank)

Anchor contract: emits id="stage-panel-{N}" on the <stage-panel> custom element.
Matches stage-selector.liquid's href="#stage-panel-N" cards.

Impact v6.9.1 conventions:
- Section-scoped CSS variables under #shopify-section-{{ section.id }}
- Custom element wrapper <stage-panel> with explicit display:block
- No reveal-on-scroll attributes
- Image_tag with widths array; lazy loading on product images

v1 deferrals (polish list):
- Add-to-bag on product cards (currently links to PDP only)
- Variant display on product cards (shows product.title only)
- Scrollspy active-state tracking on the selector when this panel enters viewport
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --panel-bg: {{ section.settings.panel_bg.rgb }};
    --panel-padding-d: {{ section.settings.padding_d }}px;
    --panel-padding-m: {{ section.settings.padding_m }}px;
    --panel-pill-color: {{ section.settings.pill_color.rgb }};
    --panel-heading-color: {{ section.settings.heading_color.rgb }};
    --panel-heading-size: {{ section.settings.heading_size_m }}px;
    --panel-body-size: {{ section.settings.body_size }}px;
    --panel-milestone-size: {{ section.settings.milestone_size }}px;
    --panel-product-img-size: {{ section.settings.product_img_size }}px;
    --panel-product-name-size: {{ section.settings.product_name_size }}px;
    --panel-product-price-size: {{ section.settings.product_price_size }}px;
    --panel-quote-size: {{ section.settings.quote_size }}px;
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --panel-heading-size: {{ section.settings.heading_size_d }}px;
    }
  }

  /* Wrapper */
  #shopify-section-{{ section.id }} .stage-panel {
    display: block;
    background-color: rgb(var(--panel-bg));
    padding: var(--panel-padding-m) var(--container-gutter);
    scroll-margin-top: var(--header-height, 0);
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .stage-panel {
      padding: var(--panel-padding-d) var(--container-gutter);
    }
  }

  /* Inner content */
  #shopify-section-{{ section.id }} .stage-panel__inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
  }

  /* Pill */
  #shopify-section-{{ section.id }} .stage-panel__pill {
    display: inline-block;
    padding: var(--spacing-1-5) var(--spacing-3);
    background: rgb(var(--panel-pill-color));
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: var(--rounded-full);
    margin-bottom: var(--spacing-4);
  }

  /* Heading */
  #shopify-section-{{ section.id }} .stage-panel__heading {
    margin: 0 0 var(--spacing-3);
    font-family: var(--heading-font-family);
    font-weight: var(--heading-font-weight);
    font-size: var(--panel-heading-size);
    line-height: 1.2;
    color: rgb(var(--panel-heading-color));
  }

  /* Body */
  #shopify-section-{{ section.id }} .stage-panel__body {
    margin: 0 0 var(--spacing-8);
    font-size: var(--panel-body-size);
    line-height: 1.6;
    color: rgb(var(--text-primary) / 0.85);
    max-width: 60ch;
  }

  /* Milestones — 2x2 */
  #shopify-section-{{ section.id }} .stage-panel__milestones {
    list-style: none;
    margin: 0 0 var(--spacing-8);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-3);
  }

  #shopify-section-{{ section.id }} .stage-panel__milestone {
    padding: var(--spacing-4);
    background: rgb(var(--doddl-color-bg));
    border-left: 3px solid rgb(var(--panel-pill-color));
    border-radius: 0 var(--rounded) var(--rounded) 0;
    font-size: var(--panel-milestone-size);
    line-height: 1.4;
  }

  /* Shop row */
  #shopify-section-{{ section.id }} .stage-panel__shop-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-5);
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }

  #shopify-section-{{ section.id }} .stage-panel__shop-label {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(var(--panel-heading-color));
  }

  /* Products grid */
  #shopify-section-{{ section.id }} .stage-panel__products {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 60vw;
    gap: var(--spacing-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--spacing-3);
    margin-bottom: var(--spacing-8);
  }

  #shopify-section-{{ section.id }} .stage-panel__products::-webkit-scrollbar {
    display: none;
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .stage-panel__products {
      grid-auto-flow: row;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      grid-auto-columns: auto;
      overflow: visible;
    }
  }

  /* Product card */
  #shopify-section-{{ section.id }} .stage-panel__product {
    position: relative;
    scroll-snap-align: start;
    border: 2px solid transparent;
    border-radius: var(--rounded);
    padding: var(--spacing-3);
    background: rgb(var(--background-primary));
    transition: border-color 200ms ease;
  }

  #shopify-section-{{ section.id }} .stage-panel__product.is-best-value {
    border-color: rgb(var(--panel-pill-color));
  }

  #shopify-section-{{ section.id }} .stage-panel__best-badge {
    display: none;
    position: absolute;
    top: var(--spacing-2);
    right: var(--spacing-2);
    padding: 2px 8px;
    background: rgb(var(--panel-pill-color));
    color: white;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: var(--rounded-full);
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .stage-panel__product.is-best-value .stage-panel__best-badge {
    display: block;
  }

  #shopify-section-{{ section.id }} .stage-panel__product-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .stage-panel__product-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgb(var(--doddl-color-bg));
    border-radius: var(--rounded-sm);
    margin-bottom: var(--spacing-2);
  }

  #shopify-section-{{ section.id }} .stage-panel__product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .stage-panel__product-name {
    margin: 0 0 var(--spacing-1);
    font-size: var(--panel-product-name-size);
    font-weight: 600;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .stage-panel__product-price {
    margin: 0;
    font-size: var(--panel-product-price-size);
    font-weight: 700;
    color: rgb(var(--doddl-color-primary));
  }

  /* Empty placeholder */
  #shopify-section-{{ section.id }} .stage-panel__placeholder {
    padding: var(--spacing-10) var(--spacing-6);
    border: 2px dashed rgb(var(--text-primary) / 0.18);
    border-radius: var(--rounded);
    text-align: center;
    color: rgb(var(--text-primary) / 0.55);
    font-size: var(--text-sm);
    margin-bottom: var(--spacing-8);
  }

  #shopify-section-{{ section.id }} .stage-panel__placeholder code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: rgb(var(--text-primary) / 0.06);
    padding: 1px 6px;
    border-radius: var(--rounded-xs);
  }

  /* Expert quote */
  #shopify-section-{{ section.id }} .stage-panel__expert {
    margin: 0 0 var(--spacing-8);
    padding: var(--spacing-6);
    background: rgb(var(--doddl-color-bg));
    border-left: 4px solid rgb(var(--panel-pill-color));
    border-radius: 0 var(--rounded) var(--rounded) 0;
  }

  #shopify-section-{{ section.id }} .stage-panel__quote {
    margin: 0 0 var(--spacing-3);
    font-style: italic;
    font-size: var(--panel-quote-size);
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .stage-panel__quote-attr {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }

  #shopify-section-{{ section.id }} .stage-panel__expert-name {
    font-style: normal;
    font-weight: 700;
    font-size: var(--text-sm);
    color: rgb(var(--panel-heading-color));
  }

  #shopify-section-{{ section.id }} .stage-panel__expert-role {
    font-size: var(--text-sm);
    color: rgb(var(--text-primary) / 0.7);
  }

  #shopify-section-{{ section.id }} .stage-panel__trust-list {
    list-style: none;
    margin: var(--spacing-3) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  #shopify-section-{{ section.id }} .stage-panel__trust-pill {
    padding: 2px 10px;
    background: rgb(var(--text-primary) / 0.06);
    color: rgb(var(--text-primary) / 0.7);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: var(--rounded-full);
  }

  /* Next-stage teaser */
  #shopify-section-{{ section.id }} .stage-panel__next {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding: var(--spacing-5);
    background: rgb(var(--doddl-color-bg));
    border-radius: var(--rounded);
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .stage-panel__next-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(var(--panel-pill-color));
    color: white;
    border-radius: 50%;
    font-size: 20px;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .stage-panel__next-content {
    flex: 1 1 200px;
  }

  #shopify-section-{{ section.id }} .stage-panel__next-label {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--text-primary) / 0.55);
  }

  #shopify-section-{{ section.id }} .stage-panel__next-heading {
    margin: 2px 0 var(--spacing-1);
    font-weight: 700;
    color: rgb(var(--panel-heading-color));
  }

  #shopify-section-{{ section.id }} .stage-panel__next-body {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.5;
    color: rgb(var(--text-primary) / 0.7);
  }

  #shopify-section-{{ section.id }} .stage-panel__next-cta {
    flex: 0 0 auto;
  }
</style>

