{% comment %}
Stage intro — standalone section for eyebrow + split heading + body.
Sits between trust-bar and stage-journey-tabs on the homepage.
Fully configurable from the theme editor — no hardcoded values.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .stage-intro {
    text-align: {{ section.settings.text_align }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding-left: var(--container-gutter);
    padding-right: var(--container-gutter);
    background-color: {{ section.settings.bg_color }};
  }
  #shopify-section-{{ section.id }} .stage-intro__eyebrow {
    display: block;
    margin: 0 0 12px;
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: {% if section.settings.eyebrow_bold %}700{% else %}400{% endif %};
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
  }
  #shopify-section-{{ section.id }} .stage-intro__heading {
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
    font-family: {% if section.settings.use_theme_font %}var(--heading-font-family){% else %}var(--text-font-family){% endif %};
    font-weight: {% if section.settings.heading_bold %}800{% else %}400{% endif %};
    line-height: 1.2;
  }
  #shopify-section-{{ section.id }} .stage-intro__heading-main {
    display: inline;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
  }
  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .stage-intro__heading-main {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
  #shopify-section-{{ section.id }} .stage-intro__heading-accent {
    display: inline;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_accent_color }};
  }
  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .stage-intro__heading-accent {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }
  #shopify-section-{{ section.id }} .stage-intro__body {
    margin: 0;
    font-size: {{ section.settings.body_size }}px;
    font-weight: {% if section.settings.body_bold %}700{% else %}400{% endif %};
    color: {{ section.settings.body_color }};
    line-height: 1.6;
    max-width: {{ section.settings.body_max_width }}px;
    margin-left: {% if section.settings.text_align == 'center' %}auto{% else %}0{% endif %};
    margin-right: {% if section.settings.text_align == 'center' %}auto{% else %}0{% endif %};
  }
</style>

<div class="stage-intro">
  {%- if section.settings.eyebrow != blank -%}
    <span class="stage-intro__eyebrow">{{ section.settings.eyebrow | escape }}</span>
  {%- endif -%}

  {%- if section.settings.heading_1 != blank or section.settings.heading_2 != blank -%}
    <h2 class="stage-intro__heading">
      {%- if section.settings.heading_1 != blank -%}
        <span class="stage-intro__heading-main">{{ section.settings.heading_1 | escape }} </span>
      {%- endif -%}
      {%- if section.settings.heading_2 != blank -%}
        <span class="stage-intro__heading-accent">{{ section.settings.heading_2 | escape }}</span>
      {%- endif -%}
    </h2>
  {%- endif -%}

  {%- if section.settings.body != blank -%}
    <p class="stage-intro__body">{{ section.settings.body | escape | newline_to_br }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Stage Intro",
  "settings": [
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Doddl Journey"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow colour",
      "default": "#2dd4bf"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_bold",
      "label": "Bold eyebrow",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading — main colour",
      "default": "The right tool at the",
      "info": "Displays inline with heading accent. Leave blank to use only accent line."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading main colour",
      "default": "#2f1562"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading — accent colour",
      "default": "right stage",
      "info": "Displays inline after main heading in the accent colour."
    },
    {
      "type": "color",
      "id": "heading_accent_color",
      "label": "Heading accent colour",
      "default": "#2dd4bf"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size — desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading font size — mobile",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Bold heading",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "use_theme_font",
      "label": "Use heading font (unchecked = body font)",
      "default": true
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Space below heading",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Every child develops at their own pace — but the developmental window for each stage is real, and the right tool makes a measurable difference. doddl is engineered for exactly where your child is right now."
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body colour",
      "default": "#444444"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "body_bold",
      "label": "Bold body",
      "default": false
    },
    {
      "type": "range",
      "id": "body_max_width",
      "label": "Body max width",
      "min": 400,
      "max": 1200,
      "step": 40,
      "default": 680,
      "unit": "px",
      "info": "Keeps body text readable at wide viewports"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section max width",
      "min": 400,
      "max": 1400,
      "step": 40,
      "default": 800,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    }
  ],
  "presets": [
    { "name": "Stage Intro" }
  ]
}
{% endschema %}
