    {
      "type": "color",
      "id": "cta1_color",
      "label": "Button colour",
      "default": "#30BEAA"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Label",
      "default": "Shop bundles"
