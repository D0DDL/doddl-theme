{%- render 'section-spacing-collapsing' -%}

{{ 'doddl-stage-journey-tabs.js' | asset_url | script_tag }}

{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
CSS

Stage journey tabs — homepage core interactive section. Per build-brief Section 3.3.
5 stages (0–4). Stage 0 = email capture (Klaviyo or native fallback). Stages 1–4 = product grids.
Per-stage settings flat per brief (s0_*, s1_*, …). 124 schema settings total. Web Component
<stage-journey-tabs> registered in assets/doddl-stage-journey-tabs.js handles tab switching,
?stage=N deep-link, and best-value tag highlighting.

Anchor ID configurable, default "stage-tabs" so the hero-split CTA can scroll here.
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --tabs-bg: rgb(var(--doddl-color-bg));
    --tabs-tab-bg: {{ section.settings.tab_bg.rgb }};
    --tabs-active-color: {{ section.settings.tab_active_color.rgb }};
    --tabs-tab-font-size: {{ section.settings.tab_font_size }}px;
    --tabs-tab-age-size: {{ section.settings.tab_age_size }}px;
    --tabs-intro-heading-size: {{ section.settings.intro_heading_size }}px;
    --tabs-intro-heading-color: {{ section.settings.intro_heading_color.rgb }};
    --tabs-intro-body-size: {{ section.settings.intro_body_size }}px;
    --tabs-sub-heading-size: {{ section.settings.sub_heading_size }}px;
    --tabs-product-img-size: {{ section.settings.product_img_size }}px;
    --tabs-product-name-size: {{ section.settings.product_name_size }}px;
    --tabs-product-price-size: {{ section.settings.product_price_size }}px;
    --tabs-image-size: {{ section.settings.tab_image_size | default: 88 }}px;
  }

  /* Wrapper */
  #shopify-section-{{ section.id }} .stage-tabs {
    display: block;
    background-color: rgb(var(--background-primary));
  }

  /* Intro */
  #shopify-section-{{ section.id }} .stage-tabs__intro {
    text-align: center;
    padding: var(--spacing-10) var(--container-gutter) var(--spacing-6);
    max-width: 720px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .stage-tabs__eyebrow {
    margin: 0 0 var(--spacing-3);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--tabs-active-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__heading {
    margin: 0 0 var(--spacing-3);
    font-family: var(--heading-font-family);
    font-weight: var(--heading-font-weight);
    font-size: var(--tabs-intro-heading-size);
    line-height: 1.2;
    color: rgb(var(--tabs-intro-heading-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__heading-main {
    display: block;
    color: rgb(var(--tabs-intro-heading-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__heading-accent {
    display: block;
    color: rgb(var(--tabs-active-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__intro-body {
    margin: 0 0 var(--spacing-4);
    font-size: var(--tabs-intro-body-size);
    line-height: 1.6;
    color: rgb(var(--text-primary) / 0.8);
  }

  #shopify-section-{{ section.id }} .stage-tabs__sub-heading {
    text-align: left;
    font-size: 32px;
    font-weight: 800;
    color: rgb(var(--text-primary));
    margin: 0 0 var(--spacing-4);
  }

  #shopify-section-{{ section.id }} .stage-tabs__instruction {
    margin: 0;
    font-size: var(--text-sm);
    color: rgb(var(--text-primary) / 0.6);
  }

  /* Tab strip */
  #shopify-section-{{ section.id }} .stage-tabs__tabstrip {
    display: flex;
    justify-content: center;
    gap: 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  #shopify-section-{{ section.id }} .stage-tabs__tabstrip::-webkit-scrollbar { display: none; }

  #shopify-section-{{ section.id }} .stage-tabs__tab {
    flex: 1;
    min-width: 120px;
    max-width: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: var(--spacing-6) var(--spacing-3) var(--spacing-4);
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab.is-active {
    border-bottom-color: rgb(var(--tabs-active-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab-image-wrap {
    position: relative;
    width: {{ section.settings.tab_image_size | default: 88 }}px;
    height: {{ section.settings.tab_image_size | default: 88 }}px;
    margin-bottom: var(--spacing-3);
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid transparent;
    transition: border-color 0.2s;
    background: #f0ecff;
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab.is-active .stage-tabs__tab-img {
    border-color: rgb(var(--tabs-active-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab-badge {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #e8e2f7;
    color: #2f1562;
    font-size: 16px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    margin-bottom: var(--spacing-2);
    transition: background 0.2s, color 0.2s;
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab.is-active .stage-tabs__tab-badge {
    background: rgb(var(--tabs-active-color));
    color: #ffffff;
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab-icon--emoji {
    width: {{ section.settings.tab_image_size | default: 88 }}px;
    height: {{ section.settings.tab_image_size | default: 88 }}px;
    border-radius: 50%;
    background: #f0ecff;
    border: 3px solid transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    margin-bottom: var(--spacing-3);
    transition: border-color 0.2s;
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab.is-active .stage-tabs__tab-icon--emoji {
    border-color: rgb(var(--tabs-active-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab-name {
    font-size: {{ section.settings.tab_font_size | default: 12 }}px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #2f1562;
    margin-bottom: 2px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab.is-active .stage-tabs__tab-name {
    color: rgb(var(--tabs-active-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__tab-age {
    font-size: {{ section.settings.tab_age_size | default: 11 }}px;
    color: rgb(var(--text-primary) / 0.5);
    text-align: center;
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .stage-tabs__tab {
      min-width: 80px;
      padding: var(--spacing-4) var(--spacing-2) var(--spacing-3);
    }
    #shopify-section-{{ section.id }} .stage-tabs__tab-image-wrap,
    #shopify-section-{{ section.id }} .stage-tabs__tab-icon--emoji {
      width: 56px;
      height: 56px;
    }
    #shopify-section-{{ section.id }} .stage-tabs__tab-badge {
      width: 28px;
      height: 28px;
      font-size: 13px;
    }
    #shopify-section-{{ section.id }} .stage-tabs__tab-name {
      font-size: 10px;
    }
  }

  /* Panels */
  #shopify-section-{{ section.id }} .stage-tabs__panel {
    display: none;
    padding: var(--spacing-10) var(--container-gutter);
    max-width: var(--container-max-width);
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .stage-tabs__panel.is-active {
    display: block;
  }

  #shopify-section-{{ section.id }} .stage-tabs__pill {
    display: inline-block;
    padding: var(--spacing-1-5) var(--spacing-3);
    border-radius: var(--rounded-full);
    background: rgb(var(--tabs-active-color));
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .stage-tabs__panel-heading {
    margin: var(--spacing-4) 0 var(--spacing-3);
    font-family: var(--heading-font-family);
    font-weight: var(--heading-font-weight);
    font-size: var(--tabs-intro-heading-size);
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .stage-tabs__panel-body {
    margin: 0 0 var(--spacing-6);
    font-size: var(--tabs-intro-body-size);
    line-height: 1.6;
    color: rgb(var(--text-primary) / 0.8);
    max-width: 60ch;
  }

  /* Milestones 2x2 */
  #shopify-section-{{ section.id }} .stage-tabs__milestones {
    list-style: none;
    margin: 0 0 var(--spacing-8);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-3);
  }

  #shopify-section-{{ section.id }} .stage-tabs__milestone {
    padding: var(--spacing-4);
    border-left: 3px solid rgb(var(--tabs-active-color));
    background: rgb(var(--doddl-color-bg));
    border-radius: 0 var(--rounded) var(--rounded) 0;
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  /* Stage 0 — email capture */
  #shopify-section-{{ section.id }} .stage-tabs__email {
    background: rgb(var(--doddl-color-bg));
    padding: var(--spacing-8);
    border-radius: var(--rounded-lg);
    margin-bottom: var(--spacing-8);
  }

  #shopify-section-{{ section.id }} .stage-tabs__email-heading {
    margin: 0 0 var(--spacing-2);
    font-weight: 700;
    font-size: var(--text-lg);
    color: rgb(var(--doddl-color-primary));
  }

  #shopify-section-{{ section.id }} .stage-tabs__email-body {
    margin: 0 0 var(--spacing-4);
    color: rgb(var(--text-primary) / 0.8);
  }

  #shopify-section-{{ section.id }} .stage-tabs__email-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} .stage-tabs__email-form {
      flex-direction: row;
      align-items: stretch;
    }
  }

  #shopify-section-{{ section.id }} .stage-tabs__email-input {
    flex: 1 1 auto;
    height: var(--input-height);
    padding: 0 var(--input-padding-inline);
    border: 1px solid rgb(var(--text-primary) / 0.2);
    border-radius: var(--rounded-input);
    background: white;
    font-size: var(--text-base);
    font-family: inherit;
  }

  /* Stages 1–4 — products */
  #shopify-section-{{ section.id }} .stage-tabs__shop-cta-row {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--spacing-5);
  }

  #shopify-section-{{ section.id }} .stage-tabs__products {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 60vw;
    gap: var(--spacing-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--spacing-2);
    margin-bottom: var(--spacing-8);
  }

  #shopify-section-{{ section.id }} .stage-tabs__products::-webkit-scrollbar {
    display: none;
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .stage-tabs__products {
      grid-auto-flow: row;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      grid-auto-columns: auto;
      overflow: visible;
    }
  }

  #shopify-section-{{ section.id }} .stage-tabs__product {
    position: relative;
    scroll-snap-align: start;
    border: 2px solid transparent;
    border-radius: var(--rounded);
    padding: var(--spacing-3);
    background: rgb(var(--background-primary));
    transition: border-color 120ms ease;
  }

  #shopify-section-{{ section.id }} .stage-tabs__product.is-best-value {
    border-color: rgb(var(--tabs-active-color));
  }

  #shopify-section-{{ section.id }} .stage-tabs__best-value-badge {
    display: none;
    position: absolute;
    top: var(--spacing-2);
    right: var(--spacing-2);
    padding: 2px 8px;
    background: rgb(var(--tabs-active-color));
    color: white;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: var(--rounded-full);
  }

  #shopify-section-{{ section.id }} .stage-tabs__product.is-best-value .stage-tabs__best-value-badge {
    display: block;
  }

  #shopify-section-{{ section.id }} .stage-tabs__product-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .stage-tabs__product-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgb(var(--doddl-color-bg));
    border-radius: var(--rounded-sm);
  }

  #shopify-section-{{ section.id }} .stage-tabs__product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .stage-tabs__product-name {
    margin: var(--spacing-2) 0 var(--spacing-1);
    font-size: var(--tabs-product-name-size);
    font-weight: 600;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .stage-tabs__product-price {
    margin: 0;
    font-size: var(--tabs-product-price-size);
    font-weight: 700;
    color: rgb(var(--doddl-color-primary));
  }

  /* Empty collection placeholder */
  #shopify-section-{{ section.id }} .stage-tabs__placeholder {
    padding: var(--spacing-10) var(--spacing-6);
    border: 2px dashed rgb(var(--text-primary) / 0.18);
    border-radius: var(--rounded);
    text-align: center;
    color: rgb(var(--text-primary) / 0.55);
    font-size: var(--text-sm);
    margin-bottom: var(--spacing-8);
  }

  #shopify-section-{{ section.id }} .stage-tabs__placeholder code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: rgb(var(--text-primary) / 0.06);
    padding: 1px 6px;
    border-radius: var(--rounded-xs);
  }

  /* Expert quote */
  #shopify-section-{{ section.id }} .stage-tabs__expert {
    margin: var(--spacing-6) 0;
    padding: var(--spacing-6);
    border-left: 4px solid rgb(var(--tabs-active-color));
    background: rgb(var(--doddl-color-bg));
    border-radius: 0 var(--rounded) var(--rounded) 0;
  }

  #shopify-section-{{ section.id }} .stage-tabs__expert-quote {
    margin: 0 0 var(--spacing-2);
    font-size: var(--text-base);
    font-style: italic;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .stage-tabs__expert-attr {
    font-size: var(--text-sm);
    font-weight: 600;
    font-style: normal;
    color: rgb(var(--text-primary) / 0.7);
  }

  /* Next stage teaser */
  #shopify-section-{{ section.id }} .stage-tabs__next {
    margin-top: var(--spacing-8);
    padding-top: var(--spacing-5);
    border-top: 1px solid rgb(var(--text-primary) / 0.1);
  }

  #shopify-section-{{ section.id }} .stage-tabs__next-heading {
    margin: 0 0 var(--spacing-2);
    font-weight: 700;
    color: rgb(var(--doddl-color-primary));
  }

  #shopify-section-{{ section.id }} .stage-tabs__next-body {
    margin: 0;
    color: rgb(var(--text-primary) / 0.7);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  #shopify-section-{{ section.id }} .section {
    padding-top: 0 !important;
  }


  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="0"] .stage-tabs__tab-badge { background: {{ section.settings.s0_badge_color | default: "#E8A020" }}; color: #fff; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="1"] .stage-tabs__tab-badge { background: {{ section.settings.s1_badge_color | default: "#2DD4BF" }}; color: #fff; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="2"] .stage-tabs__tab-badge { background: {{ section.settings.s2_badge_color | default: "#A78BFA" }}; color: #fff; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="3"] .stage-tabs__tab-badge { background: {{ section.settings.s3_badge_color | default: "#60A5FA" }}; color: #fff; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="4"] .stage-tabs__tab-badge { background: {{ section.settings.s4_badge_color | default: "#9CA3AF" }}; color: #fff; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="0"].is-active .stage-tabs__tab-name { color: {{ section.settings.s0_badge_color | default: "#E8A020" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="1"].is-active .stage-tabs__tab-name { color: {{ section.settings.s1_badge_color | default: "#2DD4BF" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="2"].is-active .stage-tabs__tab-name { color: {{ section.settings.s2_badge_color | default: "#A78BFA" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="3"].is-active .stage-tabs__tab-name { color: {{ section.settings.s3_badge_color | default: "#60A5FA" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="4"].is-active .stage-tabs__tab-name { color: {{ section.settings.s4_badge_color | default: "#9CA3AF" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="0"].is-active { border-bottom-color: {{ section.settings.s0_badge_color | default: "#E8A020" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="1"].is-active { border-bottom-color: {{ section.settings.s1_badge_color | default: "#2DD4BF" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="2"].is-active { border-bottom-color: {{ section.settings.s2_badge_color | default: "#A78BFA" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="3"].is-active { border-bottom-color: {{ section.settings.s3_badge_color | default: "#60A5FA" }}; }
  #shopify-section-{{ section.id }} .stage-tabs__tab[data-stage-tab="4"].is-active { border-bottom-color: {{ section.settings.s4_badge_color | default: "#9CA3AF" }}; }

</style>

{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
LIQUID
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign default_active = section.settings.default_active_stage | times: 1 -%}
{%- assign anchor = section.settings.anchor_id | default: 'stage-tabs' -%}

<div {% render 'section-properties' %}>
  <stage-journey-tabs class="stage-tabs" id="{{ anchor | escape }}">

    {%- comment -%} Intro block {%- endcomment -%}
    <div class="stage-tabs__intro">
      {%- if section.settings.show_intro -%}
        {%- if section.settings.intro_tag != blank -%}
          <p class="stage-tabs__eyebrow">{{ section.settings.intro_tag | escape }}</p>
        {%- endif -%}

        <h2 class="stage-tabs__heading">
          {%- if section.settings.intro_heading_1 != blank -%}
            <span class="stage-tabs__heading-main">{{ section.settings.intro_heading_1 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.intro_heading_2 != blank -%}
            <span class="stage-tabs__heading-accent">{{ section.settings.intro_heading_2 | escape }}</span>
          {%- endif -%}
        </h2>

        {%- if section.settings.intro_body_text != blank -%}
          <p class="stage-tabs__intro-body">{{ section.settings.intro_body_text | escape | newline_to_br }}</p>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.sub_heading != blank -%}
        <p class="stage-tabs__sub-heading">{{ section.settings.sub_heading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.instruction != blank -%}
        <p class="stage-tabs__instruction">{{ section.settings.instruction | escape }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Tab strip {%- endcomment -%}
    <div class="stage-tabs__tabstrip" role="tablist">
      {%- for i in (0..4) -%}
        {%- assign s = 's' | append: i -%}
        {%- assign is_active = false -%}
        {%- if forloop.index0 == default_active -%}{%- assign is_active = true -%}{%- endif -%}
        <button
          type="button"
          role="tab"
          class="stage-tabs__tab{% if is_active %} is-active{% endif %}"
          data-stage-tab="{{ i }}"
          aria-selected="{% if is_active %}true{% else %}false{% endif %}"
          aria-controls="stage-panel-{{ section.id }}-{{ i }}"
        >
          {%- assign icon_key = s | append: '_icon' -%}
          {%- assign name_key = s | append: '_name' -%}
          {%- assign age_key = s | append: '_age' -%}
          {%- assign img_key = s | append: '_tab_image' -%}
          {%- assign tab_img = section.settings[img_key] -%}
          {%- if tab_img != blank -%}
            <span class="stage-tabs__tab-image-wrap">
              <img src="{{ tab_img | image_url: width: 200 }}" alt="{{ section.settings[name_key] | escape }}" width="88" height="88" loading="eager" class="stage-tabs__tab-img">
            </span>
          {%- elsif section.settings[icon_key] != blank -%}
            <span class="stage-tabs__tab-icon--emoji" aria-hidden="true">{{ section.settings[icon_key] | escape }}</span>
          {%- endif -%}
          <span class="stage-tabs__tab-badge" aria-hidden="true">{{ i }}</span>
          <span class="stage-tabs__tab-name">{{ section.settings[name_key] | escape }}</span>
          {%- if section.settings[age_key] != blank -%}
            <span class="stage-tabs__tab-age">{{ section.settings[age_key] | escape }}</span>
          {%- endif -%}
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%} Panels {%- endcomment -%}
    {%- for i in (0..4) -%}
      {%- assign s = 's' | append: i -%}
      {%- assign is_active = false -%}
      {%- if forloop.index0 == default_active -%}{%- assign is_active = true -%}{%- endif -%}
      {%- assign pill_key = s | append: '_pill' -%}
      {%- assign heading_key = s | append: '_heading' -%}
      {%- assign body_key = s | append: '_body' -%}

      <div
        class="stage-tabs__panel{% if is_active %} is-active{% endif %}"
        data-stage-panel="{{ i }}"
        id="stage-panel-{{ section.id }}-{{ i }}"
        role="tabpanel"
        aria-hidden="{% if is_active %}false{% else %}true{% endif %}"
      >
        {%- if section.settings[pill_key] != blank -%}
          <span class="stage-tabs__pill">{{ section.settings[pill_key] | escape }}</span>
        {%- endif -%}

        {%- if section.settings[heading_key] != blank -%}
          <h3 class="stage-tabs__panel-heading">{{ section.settings[heading_key] | escape }}</h3>
        {%- endif -%}

        {%- if section.settings[body_key] != blank -%}
          <p class="stage-tabs__panel-body">{{ section.settings[body_key] | escape | newline_to_br }}</p>
        {%- endif -%}

        {%- comment -%} Milestones 2x2 {%- endcomment -%}
        {%- assign has_milestone = false -%}
        {%- for m in (1..4) -%}
          {%- assign m_key = s | append: '_m' | append: m -%}
          {%- if section.settings[m_key] != blank -%}{%- assign has_milestone = true -%}{%- endif -%}
        {%- endfor -%}

        {%- if has_milestone -%}
          <ul class="stage-tabs__milestones" role="list">
            {%- for m in (1..4) -%}
              {%- assign m_key = s | append: '_m' | append: m -%}
              {%- if section.settings[m_key] != blank -%}
                <li class="stage-tabs__milestone">{{ section.settings[m_key] | escape }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if i == 0 -%}
          {%- comment -%} Stage 0: email capture {%- endcomment -%}
          <div class="stage-tabs__email">
            {%- if section.settings.s0_email_heading != blank -%}
              <p class="stage-tabs__email-heading">{{ section.settings.s0_email_heading | escape }}</p>
            {%- endif -%}
            {%- if section.settings.s0_email_body != blank -%}
              <p class="stage-tabs__email-body">{{ section.settings.s0_email_body | escape | newline_to_br }}</p>
            {%- endif -%}

            {%- if section.settings.s0_klaviyo_id != blank -%}
              <div class="klaviyo-form-{{ section.settings.s0_klaviyo_id | escape }}"></div>
            {%- else -%}
              <form action="/contact#contact_form" method="post" class="stage-tabs__email-form">
                <input type="hidden" name="form_type" value="contact">
                <input type="hidden" name="utf8" value="✓">
                <input type="hidden" name="contact[tags]" value="stage-0-reminder">
                <label for="stage-0-email-{{ section.id }}" class="visually-hidden">Email address</label>
                <input
                  type="email"
                  id="stage-0-email-{{ section.id }}"
                  name="contact[email]"
                  required
                  placeholder="you@example.com"
                  autocomplete="email"
                  class="stage-tabs__email-input"
                >
                <button type="submit" class="button button--xl">
                  {{- section.settings.s0_email_btn | default: 'Send me a reminder' | escape -}}
                </button>
              </form>
            {%- endif -%}
          </div>
        {%- else -%}
          {%- comment -%} Stages 1–4: products {%- endcomment -%}
          {%- assign collection_key = s | append: '_collection' -%}
          {%- assign cta_label_key = s | append: '_cta_label' -%}
          {%- assign cta_url_key = s | append: '_cta_url' -%}
          {%- assign collection_handle = section.settings[collection_key] -%}
          {%- assign stage_collection = collections[collection_handle] -%}

          {%- if section.settings[cta_label_key] != blank -%}
            <div class="stage-tabs__shop-cta-row">
              <a
                href="{{ section.settings[cta_url_key] | default: stage_collection.url | default: '#' }}"
                class="button button--xl"
              >
                {{- section.settings[cta_label_key] | escape -}}
              </a>
            </div>
          {%- endif -%}

          {%- if stage_collection != blank and stage_collection.products.size > 0 -%}
            <div class="stage-tabs__products" role="list">
              {%- for product in stage_collection.products limit: 5 -%}
                <div
                  class="stage-tabs__product"
                  role="listitem"
                  data-product-tags="{{ product.tags | join: ',' | escape }}"
                >
                  <span class="stage-tabs__best-value-badge" aria-hidden="true">Best value</span>
                  <a href="{{ product.url }}" class="stage-tabs__product-link">
                    <div class="stage-tabs__product-image">
                      {%- if product.featured_image != blank -%}
                        {{- product.featured_image
                            | image_url: width: product.featured_image.width
                            | image_tag:
                                loading: 'lazy',
                                sizes: '(max-width: 999px) 60vw, 20vw',
                                widths: '200,300,400,500,600,800',
                                class: 'stage-tabs__product-img' -}}
                      {%- else -%}
                        {{- 'product-1' | placeholder_svg_tag: 'stage-tabs__product-img' -}}
                      {%- endif -%}
                    </div>
                    <p class="stage-tabs__product-name">{{ product.title | escape }}</p>
                    <p class="stage-tabs__product-price">{{ product.price | money }}</p>
                  </a>
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            {%- assign placeholder_name_key = s | append: '_name' -%}
            {%- assign placeholder_stage_name = section.settings[placeholder_name_key] | default: 'this stage' -%}
            <div class="stage-tabs__placeholder">
              {%- if collection_handle != blank -%}
                <p>
                  Products for {{ placeholder_stage_name | escape }} will appear here once the
                  <code>{{ collection_handle | escape }}</code>
                  collection is created in Shopify.
                </p>
              {%- else -%}
                <p>
                  Products for {{ placeholder_stage_name | escape }} will appear here once a collection is selected in the section settings.
                </p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Expert quote {%- endcomment -%}
        {%- assign expert_quote_key = s | append: '_expert_quote' -%}
        {%- assign expert_attr_key = s | append: '_expert_attr' -%}
        {%- if section.settings[expert_quote_key] != blank -%}
          <blockquote class="stage-tabs__expert">
            <p class="stage-tabs__expert-quote">{{ section.settings[expert_quote_key] | escape | newline_to_br }}</p>
            {%- if section.settings[expert_attr_key] != blank -%}
              <cite class="stage-tabs__expert-attr">{{ section.settings[expert_attr_key] | escape }}</cite>
            {%- endif -%}
          </blockquote>
        {%- endif -%}

        {%- comment -%} Next stage teaser {%- endcomment -%}
        {%- assign next_heading_key = s | append: '_next_heading' -%}
        {%- assign next_body_key = s | append: '_next_body' -%}
        {%- if section.settings[next_heading_key] != blank or section.settings[next_body_key] != blank -%}
          <div class="stage-tabs__next">
            {%- if section.settings[next_heading_key] != blank -%}
              <p class="stage-tabs__next-heading">{{ section.settings[next_heading_key] | escape }}</p>
            {%- endif -%}
            {%- if section.settings[next_body_key] != blank -%}
              <p class="stage-tabs__next-body">{{ section.settings[next_body_key] | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}

  </stage-journey-tabs>
</div>

{% schema %}
{
  "name": "Stage journey tabs",
