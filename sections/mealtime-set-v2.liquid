{% comment %} mealtime-set-v2.liquid {% endcomment %}
{{ 'mealtime-set-v2.css' | asset_url | stylesheet_tag }}

<div class="ms-page">
  {%- for block in section.blocks -%}
    {%- case block.type -%}

    {%- when 'banner' -%}
      <div class="ms-banner" style="height: {{ block.settings.banner_height }}px;" {{ block.shopify_attributes }}>
        {%- if block.settings.bg_image != blank -%}
          {%- assign img_url = block.settings.bg_image | image_url: width: 1600 -%}
          <div class="ms-banner__bg" style="background-image: url('{{ img_url }}'); background-position: {{ block.settings.image_position }}; background-size: {{ block.settings.image_scale }}%;"></div>
        {%- else -%}
          <div class="ms-banner__bg ms-banner__bg--color" style="background-color: {{ block.settings.bg_color }};"></div>
        {%- endif -%}
        <div class="ms-banner__overlay" style="background: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
        <div class="ms-banner__content">
          {%- if block.settings.eyebrow != blank -%}
            <p class="ms-banner__eyebrow" style="color: {{ block.settings.eyebrow_color }}; font-size: {{ block.settings.eyebrow_size }}px;">{{ block.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h1 class="ms-banner__heading" style="font-size: {{ block.settings.heading_size }}px; color: {{ block.settings.heading_color }}; font-weight: {{ block.settings.heading_weight }};">{{ block.settings.heading }}</h1>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <p class="ms-banner__body" style="color: {{ block.settings.body_color }}; font-size: {{ block.settings.body_size }}px;">{{ block.settings.body }}</p>
          {%- endif -%}
        </div>
      </div>

    {%- when 'image_grid' -%}
      <div class="ms-image-grid" {{ block.shopify_attributes }}>
        {%- for i in (1..4) -%}
          {%- assign img_key = 'image_' | append: i -%}
          {%- assign label_key = 'label_' | append: i -%}
          {%- assign position_key = 'label_position_' | append: i -%}
          {%- assign size_key = 'label_size_' | append: i -%}
          {%- assign weight_key = 'label_weight_' | append: i -%}
          {%- assign color_key = 'label_color_' | append: i -%}
          {%- assign img = block.settings[img_key] -%}
          {%- assign label = block.settings[label_key] -%}
          {%- if img != blank -%}
            <div class="ms-image-grid__item">
              {{ img | image_url: width: 800 | image_tag: loading: 'eager', class: 'ms-image-grid__img' }}
              {%- if label != blank -%}
                <span class="ms-image-grid__label ms-image-grid__label--{{ block.settings[position_key] }}" style="font-size: {{ block.settings[size_key] }}px; font-weight: {{ block.settings[weight_key] }}; color: {{ block.settings[color_key] }};">{{ label }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- when 'hotspots' -%}
      <div class="ms-hotspots" {{ block.shopify_attributes }}>
        {%- if block.settings.section_heading != blank -%}
          <h2 class="ms-section-heading" style="font-size: {{ block.settings.heading_size }}px; color: {{ block.settings.heading_color }}; font-weight: {{ block.settings.heading_weight }};">{{ block.settings.section_heading }}</h2>
        {%- endif -%}
        {%- if block.settings.image != blank -%}
          {%- assign hs_img_url = block.settings.image | image_url: width: 1400 -%}
          <div class="ms-hotspots__wrap" style="height: {{ block.settings.image_height }}px; background-image: url('{{ hs_img_url }}'); background-position: {{ block.settings.image_position }}; background-size: {{ block.settings.image_scale }}%;">
        {%- else -%}
          <div class="ms-hotspots__wrap" style="height: {{ block.settings.image_height }}px;">
            <div class="ms-hotspots__placeholder"></div>
        {%- endif -%}
          {%- for i in (1..6) -%}
            {%- assign hs_name = 'hs_name_' | append: i -%}
            {%- assign hs_desc = 'hs_desc_' | append: i -%}
            {%- assign hs_x = 'hs_x_' | append: i -%}
            {%- assign hs_y = 'hs_y_' | append: i -%}
            {%- if block.settings[hs_name] != blank -%}
              <div class="ms-hotspot" style="left: {{ block.settings[hs_x] }}%; top: {{ block.settings[hs_y] }}%;" data-hotspot="{{ block.id }}-{{ i }}">
                <button class="ms-hotspot__btn" aria-label="{{ block.settings[hs_name] }}">+</button>
                <div class="ms-hotspot__popup">
                  <p class="ms-hotspot__popup-name" style="font-size: {{ block.settings.popup_name_size }}px;">{{ block.settings[hs_name] }}</p>
                  {%- if block.settings[hs_desc] != blank -%}
                    <p class="ms-hotspot__popup-desc" style="font-size: {{ block.settings.popup_desc_size }}px;">{{ block.settings[hs_desc] }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    {%- when 'stage_guide' -%}
      <div class="ms-stages" {{ block.shopify_attributes }}>
        {%- if block.settings.section_heading != blank -%}
          <h2 class="ms-stages__main-heading" style="font-size: {{ block.settings.heading_size }}px; color: {{ block.settings.heading_color }}; font-weight: {{ block.settings.heading_weight }};">{{ block.settings.section_heading }}</h2>
        {%- endif -%}
        <div class="ms-stages__tabs">
          {%- for i in (1..3) -%}
            {%- assign tab_name_key = 'stage_' | append: i | append: '_name' -%}
            {%- assign tab_age_key = 'stage_' | append: i | append: '_age' -%}
            <button class="ms-stages__tab{% if forloop.first %} active{% endif %}" data-tab="{{ i }}">
              <span class="ms-stages__tab-num">{{ i }}</span>
              <span class="ms-stages__tab-text">
                <span class="ms-stages__tab-name">{{ block.settings[tab_name_key] }}</span>
                <span class="ms-stages__tab-age">{{ block.settings[tab_age_key] }}</span>
              </span>
            </button>
          {%- endfor -%}
        </div>
        {%- for i in (1..3) -%}
          {%- assign heading_key = 'stage_' | append: i | append: '_heading' -%}
          {%- assign body_key = 'stage_' | append: i | append: '_body' -%}
          {%- assign age_key = 'stage_' | append: i | append: '_age' -%}
          {%- assign b1_key = 'stage_' | append: i | append: '_bullet_1' -%}
          {%- assign b2_key = 'stage_' | append: i | append: '_bullet_2' -%}
          {%- assign b3_key = 'stage_' | append: i | append: '_bullet_3' -%}
          {%- assign b4_key = 'stage_' | append: i | append: '_bullet_4' -%}
          <div class="ms-stages__panel{% if forloop.first %} active{% endif %}" data-panel="{{ i }}">
            <div class="ms-stages__panel-inner">
              <div class="ms-stages__left">
                <span class="ms-stages__pill" style="font-size: {{ block.settings.pill_size }}px;">Stage {{ i }} &middot; {{ block.settings[age_key] }}</span>
                <h3 class="ms-stages__heading" style="font-size: {{ block.settings.stage_heading_size }}px;">{{ block.settings[heading_key] }}</h3>
                <p class="ms-stages__body" style="font-size: {{ block.settings.body_size }}px;">{{ block.settings[body_key] | newline_to_br }}</p>
                <p class="ms-stages__signs-label" style="font-size: {{ block.settings.signs_label_size }}px;">Signs your child is ready:</p>
                <ul class="ms-stages__bullets">
                  {%- if block.settings[b1_key] != blank -%}<li style="font-size: {{ block.settings.bullet_size }}px;">{{ block.settings[b1_key] }}</li>{%- endif -%}
                  {%- if block.settings[b2_key] != blank -%}<li style="font-size: {{ block.settings.bullet_size }}px;">{{ block.settings[b2_key] }}</li>{%- endif -%}
                  {%- if block.settings[b3_key] != blank -%}<li style="font-size: {{ block.settings.bullet_size }}px;">{{ block.settings[b3_key] }}</li>{%- endif -%}
                  {%- if block.settings[b4_key] != blank -%}<li style="font-size: {{ block.settings.bullet_size }}px;">{{ block.settings[b4_key] }}</li>{%- endif -%}
                </ul>
              </div>
              <div class="ms-stages__right">
                <p class="ms-stages__products-label" style="font-size: {{ block.settings.signs_label_size }}px;">Products for this stage</p>
                <div class="ms-stages__products">
                  {%- for p in (1..3) -%}
                    {%- assign p_img_key = 'stage_' | append: i | append: '_p' | append: p | append: '_img' -%}
                    {%- assign p_name_key = 'stage_' | append: i | append: '_p' | append: p | append: '_name' -%}
                    {%- assign p_b1_key = 'stage_' | append: i | append: '_p' | append: p | append: '_b1' -%}
                    {%- assign p_b2_key = 'stage_' | append: i | append: '_p' | append: p | append: '_b2' -%}
                    {%- assign p_link_key = 'stage_' | append: i | append: '_p' | append: p | append: '_link' -%}
                    {%- assign p_link = block.settings[p_link_key] -%}
                    <div class="ms-stages__product-card">
                      <div class="ms-stages__product-img">
                        {%- if block.settings[p_img_key] != blank -%}
                          {{ block.settings[p_img_key] | image_url: width: 400 | image_tag: loading: 'lazy' }}
                        {%- else -%}
                          <div class="ms-stages__product-placeholder"></div>
                        {%- endif -%}
                      </div>
                      <div class="ms-stages__product-body">
                        <p class="ms-stages__product-name" style="font-size: {{ block.settings.product_name_size }}px;">{{ block.settings[p_name_key] }}</p>
                        <ul class="ms-stages__product-bullets">
                          {%- if block.settings[p_b1_key] != blank -%}<li style="font-size: {{ block.settings.product_bullet_size }}px;">{{ block.settings[p_b1_key] }}</li>{%- endif -%}
                          {%- if block.settings[p_b2_key] != blank -%}<li style="font-size: {{ block.settings.product_bullet_size }}px;">{{ block.settings[p_b2_key] }}</li>{%- endif -%}
                        </ul>
                        {%- if p_link != blank -%}
                          <a href="{{ p_link }}" class="ms-stages__product-link" style="font-size: {{ block.settings.product_bullet_size }}px;">View product &rarr;</a>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    {%- when 'intro_guide' -%}
      <div class="ms-intro" {{ block.shopify_attributes }}>
        {%- if block.settings.stage_pill != blank -%}
          <span class="ms-intro__pill" style="font-size: {{ block.settings.pill_size }}px;">{{ block.settings.stage_pill }}</span>
        {%- endif -%}
        {%- if block.settings.heading != blank -%}
          <h2 class="ms-intro__heading" style="font-size: {{ block.settings.heading_size }}px; color: {{ block.settings.heading_color }}; font-weight: {{ block.settings.heading_weight }};">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.tagline != blank -%}
          <p class="ms-intro__tagline" style="font-size: {{ block.settings.tagline_size }}px;">{{ block.settings.tagline }}</p>
        {%- endif -%}
        {%- if block.settings.body != blank -%}
          <div class="ms-intro__body" style="font-size: {{ block.settings.body_size }}px;">{{ block.settings.body }}</div>
        {%- endif -%}
        <div class="ms-milestones">
          {%- for i in (1..4) -%}
            {%- assign age_key = 'milestone_age_' | append: i -%}
            {%- assign text_key = 'milestone_text_' | append: i -%}
            {%- assign highlight_key = 'milestone_highlight_' | append: i -%}
            {%- if block.settings[age_key] != blank -%}
              <div class="ms-milestone{% if block.settings[highlight_key] %} ms-milestone--highlight{% endif %}">
                <p class="ms-milestone__age" style="font-size: {{ block.settings.milestone_size }}px;">{{ block.settings[age_key] }}</p>
                <p class="ms-milestone__text" style="font-size: {{ block.settings.milestone_size }}px;">{{ block.settings[text_key] }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    {%- when 'faq' -%}
      <div class="ms-faq" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h2 class="ms-faq__heading" style="font-size: {{ block.settings.heading_size }}px; color: {{ block.settings.heading_color }}; font-weight: {{ block.settings.heading_weight }};">{{ block.settings.heading }}</h2>
        {%- endif -%}
        <div class="ms-faq__grid">
          {%- for i in (1..6) -%}
            {%- assign q_key = 'q_' | append: i -%}
            {%- assign a_key = 'a_' | append: i -%}
            {%- if block.settings[q_key] != blank -%}
              <div class="ms-faq__item">
                <p class="ms-faq__q" style="font-size: {{ block.settings.question_size }}px;">{{ block.settings[q_key] }}</p>
                <p class="ms-faq__a" style="font-size: {{ block.settings.answer_size }}px;">{{ block.settings[a_key] }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    {%- when 'video' -%}
      <div class="ms-video" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h2 class="ms-video__heading" style="font-size: {{ block.settings.heading_size }}px; color: {{ block.settings.heading_color }}; font-weight: {{ block.settings.heading_weight }};">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.video != blank -%}
          {%- assign poster_url = '' -%}
          {%- if block.settings.poster != blank -%}
            {%- assign poster_url = block.settings.poster | image_url: width: 1400 -%}
          {%- endif -%}
          <div class="ms-video__desktop" style="max-width: {{ block.settings.video_width }}%; margin: 0 auto;">
            <div class="ms-video__wrap">
              <video class="ms-video__player" controls playsinline {% if poster_url != blank %}poster="{{ poster_url }}"{% endif %}>
                {%- for source in block.settings.video.sources -%}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {%- endfor -%}
              </video>
            </div>
          </div>
        {%- endif -%}
        {%- if block.settings.video_mobile != blank -%}
          {%- assign poster_mobile_url = '' -%}
          {%- if block.settings.poster_mobile != blank -%}
            {%- assign poster_mobile_url = block.settings.poster_mobile | image_url: width: 800 -%}
          {%- endif -%}
          <div class="ms-video__mobile">
            <div class="ms-video__wrap">
              <video class="ms-video__player" controls playsinline {% if poster_mobile_url != blank %}poster="{{ poster_mobile_url }}"{% endif %}>
                {%- for source in block.settings.video_mobile.sources -%}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {%- endfor -%}
              </video>
            </div>
          </div>
        {%- endif -%}
      </div>

    {%- when 'swatches' -%}
      <div class="ms-swatches" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h2 class="ms-swatches__heading" style="font-size: {{ block.settings.heading_size }}px;">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.subtext != blank -%}
          <p class="ms-swatches__sub" style="font-size: {{ block.settings.subtext_size }}px;">{{ block.settings.subtext }}</p>
        {%- endif -%}
        <div class="ms-swatches__row">
          {%- for i in (1..8) -%}
            {%- assign color_key = 'color_' | append: i -%}
            {%- assign name_key = 'color_name_' | append: i -%}
            {%- if block.settings[name_key] != blank -%}
              <div class="ms-swatch">
                <span class="ms-swatch__circle" style="background-color: {{ block.settings[color_key] }};"></span>
                <span class="ms-swatch__name" style="font-size: {{ block.settings.swatch_name_size }}px;">{{ block.settings[name_key] }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
          {%- if block.settings.shop_link != blank -%}
            <a href="{{ block.settings.shop_link }}" class="ms-swatches__link">{{ block.settings.shop_link_text | default: 'Shop all colours' }} &rarr;</a>
          {%- endif -%}
        </div>
      </div>

    {%- endcase -%}
  {%- endfor -%}
</div>

<script>
(function() {
  function initTabs() {
    var groups = document.querySelectorAll('.ms-stages');
    groups.forEach(function(group) {
      if (group.dataset.tabInit) return;
      group.dataset.tabInit = '1';
      var tabs = group.querySelectorAll('.ms-stages__tab');
      var panels = group.querySelectorAll('.ms-stages__panel');
      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          var target = tab.dataset.tab;
          tabs.forEach(function(t) { t.classList.remove('active'); });
          panels.forEach(function(p) { p.classList.remove('active'); });
          tab.classList.add('active');
          group.querySelector('.ms-stages__panel[data-panel="' + target + '"]').classList.add('active');
        });
      });
    });
  }

  function initHotspots() {
    var btns = document.querySelectorAll('.ms-hotspot__btn');
    btns.forEach(function(btn) {
      if (btn.dataset.hsInit) return;
      btn.dataset.hsInit = '1';
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var hotspot = btn.closest('.ms-hotspot');
        var isOpen = hotspot.classList.contains('open');
        document.querySelectorAll('.ms-hotspot').forEach(function(h) { h.classList.remove('open'); });
        if (!isOpen) hotspot.classList.add('open');
      });
    });
    document.addEventListener('click', function() {
      document.querySelectorAll('.ms-hotspot').forEach(function(h) { h.classList.remove('open'); });
    });
  }

  document.addEventListener('DOMContentLoaded', function() { initTabs(); initHotspots(); });
  window.addEventListener('load', function() { initTabs(); initHotspots(); });
  document.addEventListener('shopify:section:load', function() { setTimeout(function() { initTabs(); initHotspots(); }, 100); });
  document.addEventListener('shopify:block:select', function() { setTimeout(function() { initTabs(); initHotspots(); }, 100); });
})();
</script>

{% schema %}
{
  "name": "Mealtime Set v2",
  "max_blocks": 10,
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        { "type": "image_picker", "id": "bg_image", "label": "Background image" },
        { "type": "select", "id": "image_position", "label": "Image focal point", "options": [{ "value": "center center", "label": "Centre" }, { "value": "top center", "label": "Top" }, { "value": "bottom center", "label": "Bottom" }, { "value": "center left", "label": "Left" }, { "value": "center right", "label": "Right" }], "default": "center center" },
        { "type": "range", "id": "banner_height", "label": "Banner height", "min": 150, "max": 600, "step": 10, "default": 280, "unit": "px" },
        { "type": "range", "id": "image_scale", "label": "Image size", "min": 20, "max": 200, "step": 5, "default": 100, "unit": "%" },
        { "type": "color", "id": "bg_color", "label": "Background colour (fallback)", "default": "#f5f5f5" },
        { "type": "color", "id": "overlay_color", "label": "Overlay colour", "default": "#000000" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "default": 0, "unit": "%" },
        { "type": "header", "content": "Eyebrow" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Complete Baby to Toddler Mealtime Set" },
        { "type": "color", "id": "eyebrow_color", "label": "Eyebrow colour", "default": "#3D157D" },
        { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 8, "max": 20, "step": 1, "default": 11 },
        { "type": "header", "content": "Heading" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Everything they need from first bites to family meals" },
        { "type": "range", "id": "heading_size", "label": "Heading size", "min": 18, "max": 48, "step": 1, "default": 28 },
        { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#3D157D" },
        { "type": "select", "id": "heading_weight", "label": "Heading weight", "options": [{ "value": "600", "label": "Regular" }, { "value": "700", "label": "Bold" }, { "value": "800", "label": "Extra bold" }], "default": "800" },
        { "type": "header", "content": "Body" },
        { "type": "textarea", "id": "body", "label": "Body text", "default": "Designed to grow with your child from 6 months to 5 years." },
        { "type": "color", "id": "body_color", "label": "Body text colour", "default": "#1a1a2e" },
        { "type": "range", "id": "body_size", "label": "Body text size", "min": 10, "max": 24, "step": 1, "default": 15 }
      ]
    },
    {
      "type": "image_grid",
      "name": "Image Grid",
      "settings": [
        { "type": "header", "content": "Image 1" },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "text", "id": "label_1", "label": "Label 1", "default": "Baby Cutlery + Case" },
        { "type": "select", "id": "label_position_1", "label": "Label position", "options": [{ "value": "top-left", "label": "Top left" }, { "value": "top-right", "label": "Top right" }, { "value": "bottom-left", "label": "Bottom left" }, { "value": "bottom-right", "label": "Bottom right" }], "default": "top-left" },
        { "type": "range", "id": "label_size_1", "label": "Label size", "min": 10, "max": 28, "step": 1, "default": 14 },
        { "type": "select", "id": "label_weight_1", "label": "Label weight", "options": [{ "value": "400", "label": "Regular" }, { "value": "600", "label": "Semi bold" }, { "value": "700", "label": "Bold" }, { "value": "800", "label": "Extra bold" }], "default": "700" },
        { "type": "color", "id": "label_color_1", "label": "Label colour", "default": "#ffffff" },
        { "type": "header", "content": "Image 2" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "text", "id": "label_2", "label": "Label 2", "default": "3 Piece Cutlery + Case" },
        { "type": "select", "id": "label_position_2", "label": "Label position", "options": [{ "value": "top-left", "label": "Top left" }, { "value": "top-right", "label": "Top right" }, { "value": "bottom-left", "label": "Bottom left" }, { "value": "bottom-right", "label": "Bottom right" }], "default": "top-left" },
        { "type": "range", "id": "label_size_2", "label": "Label size", "min": 10, "max": 28, "step": 1, "default": 14 },
        { "type": "select", "id": "label_weight_2", "label": "Label weight", "options": [{ "value": "400", "label": "Regular" }, { "value": "600", "label": "Semi bold" }, { "value": "700", "label": "Bold" }, { "value": "800", "label": "Extra bold" }], "default": "700" },
        { "type": "color", "id": "label_color_2", "label": "Label colour", "default": "#ffffff" },
        { "type": "header", "content": "Image 3" },
