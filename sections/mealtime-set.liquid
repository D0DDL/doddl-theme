{% comment %} sections/mealtime-set.liquid {% endcomment %}
{{ 'mealtime-set.css' | asset_url | stylesheet_tag }}

<div class="mealtime-set-page">

  {% comment %} 1. BANNER {% endcomment %}
  {% if section.settings.banner_heading != blank %}
  <div class="ms-banner" style="background: {{ section.settings.banner_bg_colour }};">
    {% if section.settings.banner_image_left != blank %}
      <div class="ms-banner-img">
        {{ section.settings.banner_image_left | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.banner_heading }}
      </div>
    {% endif %}
    <div class="ms-banner-content">
      {% if section.settings.banner_eyebrow != blank %}
        <p class="ms-banner-eyebrow">{{ section.settings.banner_eyebrow }}</p>
      {% endif %}
      <h1 class="ms-banner-heading">{{ section.settings.banner_heading }}</h1>
      {% if section.settings.banner_body != blank %}
        <p class="ms-banner-body">{{ section.settings.banner_body }}</p>
      {% endif %}
    </div>
    {% if section.settings.banner_image_right != blank %}
      <div class="ms-banner-img">
        {{ section.settings.banner_image_right | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.banner_heading }}
      </div>
    {% endif %}
  </div>
  {% endif %}

  {% comment %} 2. STAGE PROMPT &mdash; mobile only {% endcomment %}
  <div class="ms-stage-prompt">
    <p class="ms-prompt-text">{{ section.settings.prompt_text }}</p>
    <div class="ms-prompt-pills">
      <a href="#ms-stage-1" class="ms-prompt-pill ms-pill-teal">Stage 1 &middot; 6m+</a>
      <a href="#ms-stage-2" class="ms-prompt-pill ms-pill-purple">Stage 2 &middot; 12m+</a>
      <a href="#ms-stage-3" class="ms-prompt-pill ms-pill-indigo">Stage 3 &middot; 18m+</a>
      <a href="#ms-stage-4" class="ms-prompt-pill ms-pill-deep">Stage 4 &middot; 3yr+</a>
    </div>
  </div>

  {% comment %} 3. DEVELOPMENT JOURNEY {% endcomment %}
  <div class="ms-section-label" style="font-size: {{ section.settings.journey_heading_size }}px; color: {{ section.settings.journey_heading_colour }}; font-weight: {{ section.settings.journey_heading_weight }};">{{ section.settings.journey_heading }}</div>

  <div class="ms-journey-grid">
    {% assign stage_index = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'stage' %}
        {% assign stage_index = stage_index | plus: 1 %}
        <div class="ms-stage-card" id="ms-stage-{{ stage_index }}" {{ block.shopify_attributes }}>
          <div class="ms-stage-img">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.stage_title }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'ms-placeholder-img' }}
            {% endif %}
          </div>
          <div class="ms-stage-bar ms-bar-{{ block.settings.bar_colour }}"></div>
          <div class="ms-stage-content">
            <div>
              <p class="ms-stage-lbl">{{ block.settings.stage_title }}</p>
              <p class="ms-stage-age">{{ block.settings.stage_age }}</p>
            </div>
            <ul class="ms-milestones">
              {% assign milestones = block.settings.milestones | newline_to_br | split: '<br />' %}
              {% for milestone in milestones %}
                {% assign mt = milestone | strip %}
                {% if mt != blank %}
                  <li><span class="ms-dot ms-dot-{{ block.settings.bar_colour }}"></span>{{ mt }}</li>
                {% endif %}
              {% endfor %}
            </ul>
            {% if block.settings.next_step != blank %}
              <div class="ms-next-step ms-next-{{ block.settings.bar_colour }}">{{ block.settings.next_step }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% comment %} 4. VIDEO {% endcomment %}
  {% if section.settings.video != blank %}
  <div class="ms-video-section">
    {% if section.settings.video_heading != blank %}
      <p class="ms-section-label" style="font-size: {{ section.settings.video_heading_size }}px; color: {{ section.settings.video_heading_colour }}; font-weight: {{ section.settings.video_heading_weight }};">{{ section.settings.video_heading }}</p>
    {% endif %}
    <div class="ms-video-wrapper">
      {{ section.settings.video | video_tag: autoplay: false, loop: false, controls: true, muted: false, class: 'ms-video-player' }}
    </div>
  </div>
  {% endif %}

  {% comment %} 5. PRODUCT CARDS {% endcomment %}
  <div class="ms-section-label" style="font-size: {{ section.settings.products_heading_size }}px; color: {{ section.settings.products_heading_colour }}; font-weight: {{ section.settings.products_heading_weight }};">{{ section.settings.products_heading }}</div>

  <div class="ms-product-grid">
    {% for block in section.blocks %}
      {% if block.type == 'product_card' %}
        <div class="ms-pcard ms-pcard-{{ block.settings.card_colour }}" {{ block.shopify_attributes }}>
          <div class="ms-pcard-header">
            <div>
              <p class="ms-pcard-name">{{ block.settings.product_name }}</p>
              <p class="ms-pcard-sub">{{ block.settings.product_subtitle }}</p>
            </div>
            <span class="ms-age-pill ms-pill-{{ block.settings.card_colour }}">{{ block.settings.age_pill }}</span>
          </div>
          <hr class="ms-pcard-divider ms-divider-{{ block.settings.card_colour }}">
          <ul class="ms-benefits">
            {% if block.settings.benefit_1 != blank %}
              <li><span class="ms-b-dot ms-bdot-{{ block.settings.card_colour }}"></span><div class="ms-benefit-text">{{ block.settings.benefit_1 }}</div></li>
            {% endif %}
            {% if block.settings.benefit_2 != blank %}
              <li><span class="ms-b-dot ms-bdot-{{ block.settings.card_colour }}"></span><div class="ms-benefit-text">{{ block.settings.benefit_2 }}</div></li>
            {% endif %}
            {% if block.settings.benefit_3 != blank %}
              <li><span class="ms-b-dot ms-bdot-{{ block.settings.card_colour }}"></span><div class="ms-benefit-text">{{ block.settings.benefit_3 }}</div></li>
            {% endif %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% comment %} 6. COLOUR SWATCHES {% endcomment %}
  {% assign swatch_blocks = section.blocks | where: 'type', 'colour_swatch' %}
  {% if swatch_blocks.size > 0 %}
  <div class="ms-swatches-section">
    <p class="ms-swatches-heading">{{ section.settings.swatches_heading }}</p>
    {% if section.settings.swatches_subtext != blank %}
      <p class="ms-swatches-sub">{{ section.settings.swatches_subtext }}</p>
    {% endif %}
    <div class="ms-swatches-row">
      {% for block in section.blocks %}
        {% if block.type == 'colour_swatch' %}
          <div class="ms-swatch-item" {{ block.shopify_attributes }}>
            <div class="ms-swatch" style="background: {{ block.settings.swatch_colour }};"></div>
            {% if block.settings.swatch_name != blank %}
              <p class="ms-swatch-name">{{ block.settings.swatch_name }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    {% if section.settings.swatches_link != blank and section.settings.swatches_link_text != blank %}
      <a href="{{ section.settings.swatches_link }}" class="ms-swatches-link">{{ section.settings.swatches_link_text }} &rarr;</a>
    {% endif %}
  </div>
  {% endif %}

</div>

