    { "type": "text", "id": "sign_1", "label": "Sign 1" },
    { "type": "text", "id": "sign_2", "label": "Sign 2" },
    { "type": "text", "id": "sign_3", "label": "Sign 3" },
    { "type": "text", "id": "sign_4", "label": "Sign 4" },
    { "type": "range", "id": "signs_size", "label": "Signs text size", "min": 12, "max": 17, "step": 1, "unit": "px", "default": 14 },

    { "type": "header", "content": "Celebration / encouragement line" },
    { "type": "textarea", "id": "celebration", "label": "Celebration line", "info": "Standout styled. One short, warm sentence." },
    { "type": "range", "id": "celebration_size", "label": "Celebration text size", "min": 13, "max": 19, "step": 1, "unit": "px", "default": 15 },

    { "type": "header", "content": "Find the right tools (CTA)" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Find the right tools →" },
    { "type": "url", "id": "cta_url", "label": "CTA URL", "info": "Leave blank to default to the product collection's URL." },

    { "type": "header", "content": "Community photos (3-cell grid)" },
    { "type": "paragraph", "content": "Optional. Real SEN community UGC — consent required before publishing." },
    { "type": "image_picker", "id": "ugc_1", "label": "Photo 1" },
    { "type": "text", "id": "ugc_1_alt", "label": "Photo 1 alt text" },
    { "type": "image_picker", "id": "ugc_2", "label": "Photo 2" },
    { "type": "text", "id": "ugc_2_alt", "label": "Photo 2 alt text" },
    { "type": "image_picker", "id": "ugc_3", "label": "Photo 3" },
    { "type": "text", "id": "ugc_3_alt", "label": "Photo 3 alt text" },

    { "type": "header", "content": "Family quote" },
    { "type": "paragraph", "content": "Real family story — written consent required from the family before publishing." },
    { "type": "textarea", "id": "family_quote", "label": "Family quote text" },
    { "type": "range", "id": "family_quote_size", "label": "Family quote size", "min": 13, "max": 19, "step": 1, "unit": "px", "default": 15 },
    { "type": "text", "id": "family_attr", "label": "Family attribution", "info": "e.g. Emma, mum to Archie. No age — child's first name only." },

    { "type": "header", "content": "OT quote" },
    { "type": "paragraph", "content": "Named practitioner. Sign-off required before publishing." },
    { "type": "textarea", "id": "ot_quote", "label": "OT quote text" },
    { "type": "range", "id": "ot_quote_size", "label": "OT quote size", "min": 12, "max": 18, "step": 1, "unit": "px", "default": 14 },
    { "type": "text", "id": "ot_name", "label": "OT name" },
    { "type": "text", "id": "ot_role", "label": "OT role / credentials", "info": "e.g. Paediatric OT, NHS & private" },
    { "type": "text", "id": "trust_1", "label": "Trust label 1", "default": "OT UK" },
    { "type": "text", "id": "trust_2", "label": "Trust label 2", "default": "RCSLT" },

    { "type": "header", "content": "Products" },
    { "type": "text", "id": "products_label", "label": "Products eyebrow label", "default": "Recommended for this stage" },
    { "type": "collection", "id": "collection", "label": "Product collection", "info": "Pulls up to 5 products. Tag one product 'ot-recommended' to highlight it with an aqua border and OT-pick badge." },
    { "type": "range", "id": "product_img_size", "label": "Product image size", "min": 120, "max": 260, "step": 20, "unit": "px", "default": 180 },
    { "type": "range", "id": "product_name_size", "label": "Product name size", "min": 11, "max": 16, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "product_price_size", "label": "Product price size", "min": 12, "max": 18, "step": 1, "unit": "px", "default": 14 },

    { "type": "header", "content": "Next-stage teaser" },
    { "type": "paragraph", "content": "Leave Next heading and Next body blank to hide the teaser (use this on the final stage — eating-independently). Keep language gentle and non-prescriptive." },
    { "type": "text", "id": "next_icon", "label": "Icon (emoji or short text)", "default": "→" },
    { "type": "text", "id": "next_label", "label": "Eyebrow label", "default": "When the time is right" },
    { "type": "text", "id": "next_heading", "label": "Next heading" },
    { "type": "textarea", "id": "next_body", "label": "Next body" },
    { "type": "text", "id": "next_cta", "label": "Next CTA label", "default": "Look ahead →" },
    { "type": "url", "id": "next_url", "label": "Next CTA URL", "info": "e.g. #finding-grip to scroll to the next panel on the same page." },

    { "type": "header", "content": "Section appearance" },
    { "type": "color", "id": "panel_bg", "label": "Background colour", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_d", "label": "Padding — desktop", "min": 40, "max": 120, "step": 8, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_m", "label": "Padding — mobile", "min": 24, "max": 80, "step": 8, "unit": "px", "default": 48 }
  ],
  "presets": [
    {
      "name": "SEN journey — stage panel"
    }
  ]
}
{% endschema %}
