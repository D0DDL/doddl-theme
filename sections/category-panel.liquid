{%- endcomment -%}

{%- assign anchor_id = section.settings.anchor_id | default: 'category' | handle -%}
{%- assign collection_handle = section.settings.collection -%}
{%- assign cat_collection = collections[collection_handle] -%}

<div {% render 'section-properties' %}>
  <category-panel class="catp" id="{{ anchor_id }}">
    <div class="catp__inner">
      {%- if section.settings.category_label != blank -%}
        <p class="catp__label">{{ section.settings.category_label | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="catp__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="catp__body">{{ section.settings.body | escape | newline_to_br }}</p>
      {%- endif -%}

      {%- assign has_feature = false -%}
      {%- for n in (1..4) -%}
        {%- assign f_key = 'f' | append: n -%}
        {%- if section.settings[f_key] != blank -%}{%- assign has_feature = true -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_feature -%}
        <ul class="catp__features" role="list">
          {%- for n in (1..4) -%}
            {%- assign f_key = 'f' | append: n -%}
            {%- assign f_value = section.settings[f_key] -%}
            {%- if f_value != blank -%}
              <li class="catp__feature">{{ f_value | escape }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if cat_collection != blank and cat_collection.products.size > 0 -%}
        <div class="catp__products" role="list">
          {%- for product in cat_collection.products limit: 5 -%}
            {%- assign is_best = false -%}
            {%- if product.tags contains 'best-value' -%}{%- assign is_best = true -%}{%- endif -%}
            <div class="catp__product{% if is_best %} is-best-value{% endif %}" role="listitem">
              <span class="catp__best-badge" aria-hidden="true">Best value</span>
              <a href="{{ product.url }}" class="catp__product-link">
                <div class="catp__product-image">
                  {%- if product.featured_image != blank -%}
                    {{- product.featured_image
                        | image_url: width: product.featured_image.width
                        | image_tag:
                            loading: 'lazy',
                            sizes: '(max-width: 999px) 60vw, 18vw',
                            widths: '200,300,400,500,600,800',
                            class: 'catp__product-img' -}}
                  {%- else -%}
                    {{- 'product-1' | placeholder_svg_tag: 'catp__product-img' -}}
                  {%- endif -%}
                </div>
                <p class="catp__product-name">{{ product.title | escape }}</p>
                <p class="catp__product-price">{{ product.price | money }}</p>
              </a>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="catp__placeholder">
          {%- if collection_handle != blank -%}
            <p>
              Products will appear here once the
              <code>{{ collection_handle | escape }}</code>
              collection is created in Shopify.
            </p>
          {%- else -%}
            <p>Products will appear here once a collection is selected in the section settings.</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.expert_quote != blank -%}
        <blockquote class="catp__expert">
          <p class="catp__quote-text">{{ section.settings.expert_quote | escape | newline_to_br }}</p>
          {%- if section.settings.expert_name != blank or section.settings.expert_role != blank -%}
            <div class="catp__quote-attr">
              {%- if section.settings.expert_name != blank -%}
                <cite class="catp__expert-name">{{ section.settings.expert_name | escape }}</cite>
              {%- endif -%}
              {%- if section.settings.expert_role != blank -%}
                <span class="catp__expert-role">{{ section.settings.expert_role | escape }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </blockquote>
      {%- endif -%}

      {%- if section.settings.view_all_label != blank and section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="catp__view-all">
          {{- section.settings.view_all_label | escape -}}
        </a>
      {%- endif -%}

      {%- if section.settings.crosssell_text != blank or section.settings.crosssell_label != blank -%}
        <div class="catp__crosssell">
          {%- if section.settings.crosssell_text != blank -%}
            <p class="catp__crosssell-text">{{ section.settings.crosssell_text | escape | newline_to_br }}</p>
          {%- endif -%}
          {%- if section.settings.crosssell_label != blank and section.settings.crosssell_url != blank -%}
            <a href="{{ section.settings.crosssell_url }}" class="button button--lg catp__crosssell-link">
              {{- section.settings.crosssell_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </category-panel>
</div>

{% schema %}
{
  "name": "Shop by category — panel",
  "class": "shopify-section--category-panel",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    { "type": "header", "content": "Anchor + label" },
    { "type": "text", "id": "anchor_id", "label": "Category anchor ID", "info": "Used as #anchor for cross-sell links from other panels.", "default": "baby-cutlery" },
    { "type": "text", "id": "category_label", "label": "Category eyebrow label", "default": "Baby Cutlery · Stage 1" },
    { "type": "range", "id": "label_size", "label": "Label size", "min": 9, "max": 14, "step": 1, "unit": "px", "default": 11 },

    { "type": "header", "content": "Heading and body" },
    { "type": "text", "id": "heading", "label": "Headline (H2)", "default": "First tools, first wins" },
    { "type": "range", "id": "heading_size_d", "label": "Heading size — desktop", "min": 22, "max": 42, "step": 2, "unit": "px", "default": 30 },
    { "type": "range", "id": "heading_size_m", "label": "Heading size — mobile", "min": 18, "max": 34, "step": 2, "unit": "px", "default": 24 },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#3D157D" },
    { "type": "color", "id": "accent_color", "label": "Accent colour", "info": "Tints eyebrow label, feature ticks, best-value border, expert quote accent, and view-full-range link. Defaults to doddl aqua.", "default": "#30BEAA" },
    { "type": "textarea", "id": "body", "label": "Body copy", "info": "2–3 sentences, benefit-led." },
    { "type": "range", "id": "body_size", "label": "Body size", "min": 13, "max": 19, "step": 1, "unit": "px", "default": 15 },

    { "type": "header", "content": "Features (4 bullets)" },
    { "type": "text", "id": "f1", "label": "Feature 1", "default": "Short handle — correct length for 0–12 month hand span" },
    { "type": "text", "id": "f2", "label": "Feature 2", "default": "Soft ergonomic tip — safe for new teeth" },
    { "type": "text", "id": "f3", "label": "Feature 3", "default": "Weighted for the grip your baby actually has right now" },
    { "type": "text", "id": "f4", "label": "Feature 4", "default": "Dishwasher safe — practical at every meal" },
    { "type": "range", "id": "feature_size", "label": "Feature text size", "min": 11, "max": 16, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Products" },
    { "type": "collection", "id": "collection", "label": "Product collection", "info": "Pulls up to 5 products. Tag one product 'best-value' to highlight it with an aqua border and badge." },
    { "type": "range", "id": "product_img_size", "label": "Product image size", "min": 100, "max": 260, "step": 20, "unit": "px", "default": 180 },
    { "type": "range", "id": "product_name_size", "label": "Product name size", "min": 11, "max": 16, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Expert quote" },
    { "type": "textarea", "id": "expert_quote", "label": "Quote text" },
    { "type": "range", "id": "expert_quote_size", "label": "Quote size", "min": 12, "max": 18, "step": 1, "unit": "px", "default": 14 },
    { "type": "text", "id": "expert_name", "label": "Expert name" },
    { "type": "text", "id": "expert_role", "label": "Expert role / credentials" },

    { "type": "header", "content": "View full range link" },
    { "type": "text", "id": "view_all_label", "label": "Link label", "default": "View full Baby Cutlery range →" },
    { "type": "url", "id": "view_all_url", "label": "Link URL", "info": "Set to /collections/{handle}." },

    { "type": "header", "content": "Cross-sell teaser" },
    { "type": "textarea", "id": "crosssell_text", "label": "Teaser copy", "info": "1–2 sentences linking to the next category." },
    { "type": "text", "id": "crosssell_label", "label": "Link label", "default": "Toddler Cutlery →" },
    { "type": "text", "id": "crosssell_url", "label": "Link URL", "info": "Anchor to the next category panel on this page, e.g. #toddler-cutlery." },

    { "type": "header", "content": "Section appearance" },
    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_d", "label": "Padding — desktop", "min": 40, "max": 120, "step": 8, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_m", "label": "Padding — mobile", "min": 24, "max": 64, "step": 8, "unit": "px", "default": 40 }
  ],
  "presets": [
    {
      "name": "Shop by category — panel"
    }
  ]
}
{% endschema %}
