{%- render 'section-spacing-collapsing' -%}

{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
CSS

Shop by Category — panel. Per build-brief Section 7.1.
ONE section file, 5 instances expected on /pages/shop-by-category — one per category:
Baby Cutlery, Toddler Cutlery, Plates & Bowls, Bibs, Bundles & Kits.

Layout per panel:
- Eyebrow category label
- H2 headline + body
- 4 feature bullets (specific product attributes)
- Product grid: up to 5 cards from the configured collection
- Best-value: products tagged 'best-value' get an aqua border + badge.
  Detection is server-side via {% if product.tags contains 'best-value' %}.
  (Brief specifies JS-moved-to-position-5; per standing decision #6 we keep
  the highlight server-side and skip reordering for v1.)
- Expert quote block (quote + name + role)
- "View full range →" link
- Cross-sell teaser: 1–2 sentences + link to the next category's anchor

Anchor contract: emits id="{anchor_id}" on the <category-panel> custom element.
Defaults follow the locked URL architecture (CLAUDE.md): baby-cutlery,
toddler-cutlery, plates-and-bowls, bibs, bundles-and-kits.

Impact v6.9.1 conventions:
- Section-scoped CSS variables under #shopify-section-{{ section.id }}
- Custom element wrapper <category-panel> with explicit display:block
- No reveal-on-scroll attributes
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --catp-bg: {{ section.settings.bg_color.rgb }};
    --catp-padding-d: {{ section.settings.padding_d }}px;
    --catp-padding-m: {{ section.settings.padding_m }}px;
    --catp-accent: {{ section.settings.accent_color.rgb }};
    --catp-heading-color: {{ section.settings.heading_color.rgb }};
    --catp-label-size: {{ section.settings.label_size }}px;
    --catp-heading-size: {{ section.settings.heading_size_m }}px;
    --catp-body-size: {{ section.settings.body_size }}px;
    --catp-feature-size: {{ section.settings.feature_size }}px;
    --catp-product-img-size: {{ section.settings.product_img_size }}px;
    --catp-product-name-size: {{ section.settings.product_name_size }}px;
    --catp-quote-size: {{ section.settings.expert_quote_size }}px;
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --catp-heading-size: {{ section.settings.heading_size_d }}px;
    }
  }

  /* Wrapper */
  #shopify-section-{{ section.id }} .catp {
    display: block;
    background-color: rgb(var(--catp-bg));
    padding: var(--catp-padding-m) var(--container-gutter);
    scroll-margin-top: var(--header-height, 0);
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .catp {
      padding: var(--catp-padding-d) var(--container-gutter);
    }
  }

  #shopify-section-{{ section.id }} .catp__inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
  }

  /* Eyebrow label */
  #shopify-section-{{ section.id }} .catp__label {
    margin: 0 0 var(--spacing-3);
    font-size: var(--catp-label-size);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--catp-accent));
  }

  /* Heading */
  #shopify-section-{{ section.id }} .catp__heading {
    margin: 0 0 var(--spacing-3);
    font-family: var(--heading-font-family);
    font-weight: var(--heading-font-weight);
    font-size: var(--catp-heading-size);
    line-height: 1.2;
    color: rgb(var(--catp-heading-color));
  }

  /* Body */
  #shopify-section-{{ section.id }} .catp__body {
    margin: 0 0 var(--spacing-6);
    font-size: var(--catp-body-size);
    line-height: 1.6;
    color: rgb(var(--text-primary) / 0.85);
    max-width: 65ch;
  }

  /* Features */
  #shopify-section-{{ section.id }} .catp__features {
    list-style: none;
    margin: 0 0 var(--spacing-8);
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--spacing-2);
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .catp__features {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--spacing-3) var(--spacing-6);
    }
  }

  #shopify-section-{{ section.id }} .catp__feature {
    position: relative;
    padding-left: var(--spacing-6);
    font-size: var(--catp-feature-size);
    line-height: 1.5;
    color: rgb(var(--text-primary) / 0.85);
  }

  #shopify-section-{{ section.id }} .catp__feature::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: rgb(var(--catp-accent));
    font-weight: 700;
  }

  /* Product grid */
  #shopify-section-{{ section.id }} .catp__products {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 60vw;
    gap: var(--spacing-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--spacing-3);
    margin-bottom: var(--spacing-8);
  }

  #shopify-section-{{ section.id }} .catp__products::-webkit-scrollbar {
    display: none;
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} .catp__products {
      grid-auto-flow: row;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      grid-auto-columns: auto;
      overflow: visible;
    }
  }

  #shopify-section-{{ section.id }} .catp__product {
    position: relative;
    scroll-snap-align: start;
    border: 2px solid transparent;
    border-radius: var(--rounded);
    padding: var(--spacing-3);
    background: rgb(var(--background-primary));
    transition: border-color 200ms ease;
  }

  #shopify-section-{{ section.id }} .catp__product.is-best-value {
    border-color: rgb(var(--catp-accent));
  }

  #shopify-section-{{ section.id }} .catp__best-badge {
    display: none;
    position: absolute;
    top: var(--spacing-2);
    right: var(--spacing-2);
    padding: 2px 8px;
    background: rgb(var(--catp-accent));
    color: white;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: var(--rounded-full);
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .catp__product.is-best-value .catp__best-badge {
    display: block;
  }

  #shopify-section-{{ section.id }} .catp__product-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .catp__product-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgb(var(--doddl-color-bg));
    border-radius: var(--rounded-sm);
    margin-bottom: var(--spacing-2);
  }

  #shopify-section-{{ section.id }} .catp__product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .catp__product-name {
    margin: 0 0 var(--spacing-1);
    font-size: var(--catp-product-name-size);
    font-weight: 600;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .catp__product-price {
    margin: 0;
    font-size: var(--catp-product-name-size);
    font-weight: 700;
    color: rgb(var(--doddl-color-primary));
  }

  /* Empty placeholder */
  #shopify-section-{{ section.id }} .catp__placeholder {
    padding: var(--spacing-10) var(--spacing-6);
    border: 2px dashed rgb(var(--text-primary) / 0.18);
    border-radius: var(--rounded);
    text-align: center;
    color: rgb(var(--text-primary) / 0.55);
    font-size: var(--text-sm);
    margin-bottom: var(--spacing-8);
  }

  #shopify-section-{{ section.id }} .catp__placeholder code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: rgb(var(--text-primary) / 0.06);
    padding: 1px 6px;
    border-radius: var(--rounded-xs);
  }

  /* Expert quote */
  #shopify-section-{{ section.id }} .catp__expert {
    margin: 0 0 var(--spacing-8);
    padding: var(--spacing-6);
    background: rgb(var(--doddl-color-bg));
    border-left: 4px solid rgb(var(--catp-accent));
    border-radius: 0 var(--rounded) var(--rounded) 0;
  }

  #shopify-section-{{ section.id }} .catp__quote-text {
    margin: 0 0 var(--spacing-3);
    font-style: italic;
    font-size: var(--catp-quote-size);
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .catp__quote-attr {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }

  #shopify-section-{{ section.id }} .catp__expert-name {
    font-style: normal;
    font-weight: 700;
    font-size: var(--text-sm);
    color: rgb(var(--catp-heading-color));
  }

  #shopify-section-{{ section.id }} .catp__expert-role {
    font-size: var(--text-sm);
    color: rgb(var(--text-primary) / 0.7);
  }

  /* View full range link */
  #shopify-section-{{ section.id }} .catp__view-all {
    display: inline-block;
    margin: 0 0 var(--spacing-8);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(var(--catp-accent));
    text-decoration: none;
    border-bottom: 2px solid rgb(var(--catp-accent));
    padding-bottom: 2px;
  }

  #shopify-section-{{ section.id }} .catp__view-all:hover,
  #shopify-section-{{ section.id }} .catp__view-all:focus-visible {
    color: rgb(var(--catp-heading-color));
    border-bottom-color: rgb(var(--catp-heading-color));
  }

  /* Cross-sell teaser */
  #shopify-section-{{ section.id }} .catp__crosssell {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding: var(--spacing-5);
    background: rgb(var(--doddl-color-bg));
    border-radius: var(--rounded);
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .catp__crosssell-text {
    margin: 0;
    flex: 1 1 240px;
    font-size: var(--text-sm);
    line-height: 1.5;
    color: rgb(var(--text-primary) / 0.8);
  }

  #shopify-section-{{ section.id }} .catp__crosssell-link {
    flex: 0 0 auto;
  }
</style>

