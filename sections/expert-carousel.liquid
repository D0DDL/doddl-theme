{% stylesheet %}
.embla {
  overflow: hidden;
  position: relative;
}

.embla__viewport {
  overflow: hidden;
  padding: 2em 0 2em 2em;
}

.embla__container {
  display: flex;
  gap: 0; /* Remove gap on mobile to prevent peek */
  padding-inline: var(--container-gutter);
}

.embla__slide {
  flex: 0 0 100vw; /* Full width on mobile - no peek */
  min-width: 0;
}

@media screen and (min-width: 700px) {
  .embla__slide {
    flex: 0 0 calc(75vw - var(--spacing-6));
  }
  
  .embla__container {
    gap: var(--spacing-8); /* Restore gap on larger screens */
    padding-inline: calc(var(--container-gutter) + 2.5vw);
  }
}

@media screen and (min-width: 1000px) {
  .embla__slide {
    flex: 0 0 calc(65vw - var(--spacing-8));
  }
  
  .embla__container {
    padding-inline: calc(var(--container-gutter) + 7.5vw);
  }
}

@media screen and (min-width: 1200px) {
  .embla__slide {
    flex: 0 0 calc(55vw - var(--spacing-8));
  }
  
  .embla__container {
    padding-inline: calc(var(--container-gutter) + 12.5vw);
  }
}

.expert-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-8);
  background: rgb(var(--color-background));
  padding: var(--spacing-8);
  border-radius: var(--rounded-lg);
  box-shadow: rgba(99, 99, 99, 0.2) 0px 2px 8px 0px;
  width: 100%;
  min-height: 20rem;
  height: 100%;
}

@media screen and (max-width: 699px) {
  .embla__viewport {
    padding: unset;
  }

  .embla__slide {
    flex: 0 0 100%;
    margin: 0 1em 1em 0;
  }
  .expert-card {
    flex-direction: column;
    text-align: center;
    align-items: center;
    gap: var(--spacing-6);
    padding: var(--spacing-6);
    min-height: auto;
  }
}

.expert-card__image-wrapper {
  width: 17.25rem;
  height: 17.25rem;
  overflow: hidden;
  flex: none;
}

@media screen and (max-width: 699px) {
  .expert-card__image-wrapper {
    width: 12rem;
    height: 12rem;
  }
}

.expert-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.expert-card__content {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-5);
  flex: 1;
  padding-top: var(--spacing-2);
}

.expert-card__name {
  margin: 0;
}

.expert-card__title {
  margin: 0;
}

.expert-card__text {
  line-height: 1.6;
}

.expert-card__text p {
  margin: 0 0 var(--spacing-4) 0;
}

.expert-card__text p:last-child {
  margin-bottom: 0;
}

.expert-card__button {
  margin-top: var(--spacing-4);
}

.floating-controls-container {
  position: relative;
}

.floating-controls {
  display: flex;
  gap: var(--spacing-3);
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  right: var(--spacing-6);
  z-index: 1;
}

@media screen and (max-width: 999px) {
  .floating-controls {
    position: static;
    transform: none;
    justify-content: center;
    margin-top: var(--spacing-8);
  }
}

.floating-controls .circle-button {
  background: rgb(var(--color-background));
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.embla__button:disabled {
  opacity: 0.5;
}
{% endstylesheet %}

{% javascript %}
// Initialize Embla Carousels
document.addEventListener('DOMContentLoaded', () => {
  const initializeCarousels = () => {
    if (!window.EmblaCarousel) {
      setTimeout(initializeCarousels, 100);
      return;
    }

    document.querySelectorAll('.embla').forEach(carouselElement => {
      const viewport = carouselElement.querySelector('.embla__viewport');
      if (!viewport) return;

      // Get settings from data attributes
      const autoplayEnabled = carouselElement.dataset.autoplay === 'true';
      const autoplaySpeed = parseInt(carouselElement.dataset.autoplaySpeed) * 1000 || 5000;
      const loop = carouselElement.dataset.loop !== 'false'; // Default true
      const align = carouselElement.dataset.align || 'start';
      const speed = parseInt(carouselElement.dataset.speed) || 8;
      const slidesToScroll = parseInt(carouselElement.dataset.slidesToScroll) || 1;
      const dragFree = carouselElement.dataset.dragFree === 'true';
      const skipSnaps = carouselElement.dataset.skipSnaps === 'true';
      
      // Autoplay settings
      const stopOnInteraction = carouselElement.dataset.stopOnInteraction === 'true';
      const stopOnMouseEnter = carouselElement.dataset.stopOnMouseEnter !== 'false'; // Default true
      const stopOnFocus = carouselElement.dataset.stopOnFocus !== 'false'; // Default true

      const options = {
        loop: loop,
        align: window.innerWidth < 700 ? 'center' : align, // Force center on mobile
        containScroll: skipSnaps ? false : 'trimSnaps',
        slidesToScroll: slidesToScroll,
        speed: speed,
        dragFree: dragFree
      };

      const plugins = [];

      if (autoplayEnabled && window.EmblaCarouselAutoplay) {
        plugins.push(window.EmblaCarouselAutoplay({ 
          delay: autoplaySpeed,
          stopOnInteraction: stopOnInteraction,
          stopOnMouseEnter: stopOnMouseEnter,
          stopOnFocusIn: stopOnFocus
        }));
      }

      const embla = window.EmblaCarousel(viewport, options, plugins);

      // Setup navigation buttons
      setupButtons(embla, carouselElement.id);

      // Store embla instance for cleanup
      carouselElement._embla = embla;
    });
  };

  // Setup navigation buttons
  function setupButtons(embla, carouselId) {
    const prevButton = document.querySelector(`.embla__button--prev[data-carousel="${carouselId}"]`);
    const nextButton = document.querySelector(`.embla__button--next[data-carousel="${carouselId}"]`);

    if (prevButton && nextButton) {
      prevButton.addEventListener('click', () => embla.scrollPrev());
      nextButton.addEventListener('click', () => embla.scrollNext());

      // Update button states
      const updateButtons = () => {
        prevButton.disabled = !embla.canScrollPrev();
        nextButton.disabled = !embla.canScrollNext();
      };

      embla.on('select', updateButtons);
      updateButtons();
    }
  }

  // Start initialization
  initializeCarousels();
});

// Cleanup when page unloads
window.addEventListener('beforeunload', () => {
  document.querySelectorAll('.embla').forEach(carouselElement => {
    if (carouselElement._embla) {
      carouselElement._embla.destroy();
    }
  });
});
{% endjavascript %}