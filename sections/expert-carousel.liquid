{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
CSS
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --text-color: {{ section.settings.text_color.rgb }};
    --heading-color: {{ section.settings.heading_color.rgb }};
  }
</style>

{%- comment -%}
------------------------------------------------------------------------------------------------------------------------
LIQUID
------------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<script src="https://unpkg.com/embla-carousel@8.0.0-rc14/embla-carousel.umd.js" defer></script>
<script src="https://unpkg.com/embla-carousel-autoplay@8.0.0-rc14/embla-carousel-autoplay.umd.js" defer></script>

{%- assign carousel_id = 'expert-carousel-' | append: section.id -%}

<div class="section section--padding">
  <div class="section-stack">
    {%- if section.settings.subheading != blank or section.settings.title != blank -%}
      {%- render 'section-header', 
          subheading: section.settings.subheading, 
          heading: section.settings.title,
          text_alignment: section.settings.text_alignment -%}
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="floating-controls-container">
        <div 
          id="{{ carousel_id }}" 
          class="embla"
          data-autoplay="{{ section.settings.autoplay }}"
          data-autoplay-speed="{{ section.settings.autoplay_speed }}"
          data-loop="{{ section.settings.loop }}"
          data-align="{{ section.settings.align }}"
          data-speed="{{ section.settings.speed }}"
          data-slides-to-scroll="{{ section.settings.slides_to_scroll }}"
          data-drag-free="{{ section.settings.drag_free }}"
          data-skip-snaps="{{ section.settings.skip_snaps }}"
          data-stop-on-interaction="{{ section.settings.stop_on_interaction }}"
          data-stop-on-mouse-enter="{{ section.settings.stop_on_mouse_enter }}"
          data-stop-on-focus="{{ section.settings.stop_on_focus }}"
          role="region">
          
          <div class="embla__viewport">
            <div class="embla__container">
              {%- for block in section.blocks -%}
                <div class="embla__slide" {{ block.shopify_attributes }}>
                  <div class="expert-card">
                    {%- if block.settings.image != blank -%}
                      <div class="expert-card__image-wrapper">
                        <img 
                          src="{{ block.settings.image | image_url: width: 400 }}"
                          alt="{{ block.settings.name | escape }}"
                          width="275"
                          height="275"
                          loading="lazy"
                          class="expert-card__image">
                      </div>
                    {%- endif -%}

                    <div class="expert-card__content">
                      {%- if block.settings.name != blank -%}
                        <h2 class="expert-card__name h2">{{ block.settings.name | escape }}</h2>
                      {%- endif -%}

                      {%- if block.settings.title != blank -%}
                        <p class="expert-card__title h5">{{ block.settings.title | escape }}</p>
                      {%- endif -%}

                      {%- if block.settings.content != blank -%}
                        <div class="expert-card__text prose">
                          {{ block.settings.content }}
                        </div>
                      {%- endif -%}

                      {%- if block.settings.button_text != blank and block.settings.button_url != blank -%}
                        <div class="expert-card__button">
                          {%- render 'button', 
                            content: block.settings.button_text,
                            href: block.settings.button_url,
                            size: block.settings.button_size,
                            style: block.settings.button_style,
                            secondary: block.settings.button_secondary
                          -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>

        {%- if section.blocks.size > 1 -%}
          <div class="floating-controls">
            <button class="embla__button embla__button--prev circle-button circle-button--lg circle-button--border" data-carousel="{{ carousel_id }}">
              <span class="sr-only">{{ 'general.accessibility.previous' | t }}</span>
              {%- render 'icon' with 'chevron-left' -%}
            </button>
            
            <button class="embla__button embla__button--next circle-button circle-button--lg circle-button--border" data-carousel="{{ carousel_id }}">
              <span class="sr-only">{{ 'general.accessibility.next' | t }}</span>
              {%- render 'icon' with 'chevron-right' -%}
            </button>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

