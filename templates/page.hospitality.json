        "image_EyCXT7": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/DODDL_BUNDLES_40_6255_88f7e9fa-775a-40fc-868d-83a9dc80c681.jpg",
            "media_width": 50,
            "media_position": "end",
            "text_position": "place-self-center-start text-start",
            "icon": "none",
            "icon_width": 48,
            "subheading": "",
            "title": "Bring doddl to your customers",
            "content": "<p><strong>We are growing at pace and currently expanding our network of global partners in new markets and across multiple categories. <br/></strong></p><p>In <strong>retail</strong>, doddl is <strong>attracting new customers</strong> who want to invest in high quality, innovative products that work - with a focus on value over price.</p><p>In hospitality, our products are making a positive difference in<strong> venues across the UK and Asia.</strong></p><p>In Early Years Education doddl is supporting <strong>children's development </strong>and <strong>helping them to get school ready </strong>in so many ways.   </p><p>Contact our team for more information about the benefits to you and your business.</p><p></p>",
            "link_text": "Contact us",
            "link_url": "shopify://pages/contact",
            "background": "#ffffff",
            "background_gradient": "",
            "text_color": "#301562",
            "text_gradient": "",
            "button_background": "",
            "button_text_color": ""
          }
        },
        "video_E4pTQc": {
          "type": "video",
          "settings": {
            "video": "shopify://files/videos/Be part of it. Stock doddl today.mp4",
            "external_video_url": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
            "autoplay": true,
            "media_width": 50,
            "media_position": "start",
            "text_position": "place-self-center text-center",
            "icon": "none",
            "icon_width": 48,
            "subheading": "Introducing doddl",
            "title": "",
            "content": "<p>Recommended by <a href=\"/pages/what-the-experts-think\" target=\"_blank\" title=\"What the experts think\">child development experts</a>, multiple award winning, 5-star rated by over 20,000 customers and available in 70+ countries. We are doddl. </p>",
            "link_text": "See the doddl range",
            "link_url": "shopify://collections/shop-all",
            "background": "#fbfbfb",
            "background_gradient": "",
            "text_color": "#ffffff",
            "text_gradient": "",
            "button_background": "",
            "button_text_color": ""
          }
        }
      },
