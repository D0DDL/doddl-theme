        "image_DpE9QX": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Corporate-to-classroom_png.webp",
            "media_width": 50,
            "media_position": "start",
            "text_position": "place-self-end text-end",
            "icon": "none",
            "icon_width": 48,
            "subheading": "Our Commitment to Developing Independence",
            "title": "2B Enterprising + doddl",
            "content": "<p>The <a href=\"https://www.2benterprising.co.uk/the-books/the-bumbles-of-honeywood/\" target=\"_blank\" title=\"https://www.2benterprising.co.uk/the-books/the-bumbles-of-honeywood/\">Bumbles of Honeywood Programme </a>helps develop valuable enterprising skills of primary school children across the UK. Through our partnership, a local primary school is now benefitting from a suite of resources that are curriculum mapped and aimed at inspiring and educating 4–8-year-old children in readiness for their future. The resources are designed to help children develop the skills they need to be healthy, independent and confident adults.</p>",
            "link_text": "Explore 2B Enterprising",
            "link_url": "https://www.2benterprising.co.uk",
            "background": "#ffffff",
            "background_gradient": "",
            "text_color": "#212529",
