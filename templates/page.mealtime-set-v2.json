        "stage_guide": {
          "type": "stage_guide",
          "settings": {
            "section_heading": "Grows with your child",
            "heading_size": 25,
            "heading_color": "#3d157d",
            "heading_weight": "800",
            "pill_size": 13,
            "stage_heading_size": 27,
            "body_size": 16,
            "signs_label_size": 14,
            "bullet_size": 15,
            "product_name_size": 16,
            "product_bullet_size": 15,
            "stage_1_name": "Explore, taste, try",
            "stage_1_age": "6-11 months",
            "stage_1_heading": "First foods, first wins",
            "stage_1_body": "Food on the face, hands trying, something clicking into place. doddl stage 1 products are designed for tiny hands that are just discovering what mealtimes are all about.",
            "stage_1_bullet_1": "Sitting in a high chair with a little support",
            "stage_1_bullet_2": "Reaching and grasping objects consistantly",
            "stage_1_bullet_3": "Bringing hand to mouth confidently",
            "stage_1_bullet_4": "Showing a real interest in food",
            "stage_1_p1_img": "shopify://shop_images/1_9994c785-9516-46c4-8c6b-d5788e83d89e.png",
            "stage_1_p1_name": "Baby Spoon and Fork",
            "stage_1_p1_b1": "Ergonomic handles are easy to grasp and designed to develop the palmer grasp to pincer grip",
            "stage_1_p1_b2": "Comfortable utensile ends are gentle on gums but not chewable, to avoid confusion",
            "stage_1_p1_link": "shopify://products/baby-cutlery-set-travel-case",
            "stage_1_p2_img": "shopify://shop_images/2_b3c84c53-7797-49c9-a34e-9615ca1f9c85.png",
            "stage_1_p2_name": "2-in-1 Suction Bowl",
            "stage_1_p2_b1": "Oval shape and higher back makes learning to scoop easier",
            "stage_1_p2_b2": "Lower front makes food easy to see, important for sensory development. Strong suction keeps bowl in position and can be removed to reveal a non-slip base",
            "stage_1_p2_link": "shopify://products/the-doddl-2-in-1-suction-bowl",
            "stage_1_p3_img": "shopify://shop_images/3_b333168a-9dec-4933-947f-056c7b37cfb1.png",
            "stage_1_p3_name": "Easy to Introduce",
            "stage_1_p3_b1": "Lay the baby spoon and fork on your baby's tray alongside their food and let them explore. Model cutlery use as much as possible, baby's learn by copying",
            "stage_1_p3_b2": "Load the baby spoon or fork with yoghurt or similar and lay on their tray, handle towards them. Encourage your baby to pick it up, adding plenty of enthusiasm when they do!",
            "stage_1_p3_link": "",
            "stage_2_name": "Developing Control",
            "stage_2_age": "12-24 months",
            "stage_2_heading": "I can do it myself!",
            "stage_2_body": "The desire for independence is growing and their hands are making their biggest development leap, the palmar grasp makes way for something more precise. The right tools make that transition happen faster — and with a lot less mess.",
            "stage_2_bullet_1": "Starting to pick things up between thumb and finger",
            "stage_2_bullet_2": "Attempting to scoop food",
            "stage_2_bullet_3": "Trying to self-feed for most of the meal",
            "stage_2_bullet_4": "Frustrated if you try to help!",
            "stage_2_p1_img": "shopify://shop_images/4_68ef6944-a8cb-44e7-a75f-1584b38c7dfa.png",
            "stage_2_p1_name": "2-in-1 Suction Plate",
            "stage_2_p1_b1": "Oval shape keeps food in easy reach, raised back and lipped front keeps food and snacks on the plate reducing mess",
            "stage_2_p1_b2": "Plate purposefully not sectioned to avoid creating food sensory issues. Strong suction keeps plate firmly in position.",
            "stage_2_p1_link": "",
            "stage_2_p2_img": "shopify://shop_images/5_a24ca40c-cbbe-4432-b4e1-3fdcebd711c5.png",
            "stage_2_p2_name": "Toddler Spoon and Fork",
            "stage_2_p2_b1": "Expertly shaped and weighted handle makes self-feeding easy and develops grip strength",
            "stage_2_p2_b2": "Builds co-ordination, confidence and independence while naturally encouraging the correct grip",
            "stage_2_p2_link": "shopify://products/toddler-spoon-and-fork-set",
            "stage_2_p3_img": "shopify://shop_images/6_a4e67556-bc56-478a-ae1a-7045922bfccf.png",
            "stage_2_p3_name": "Easy to Introduce",
            "stage_2_p3_b1": "Pre-load the spoon and lay it on your toddlers tray, handle facing them",
            "stage_2_p3_b2": "Once your toddler feels confident scooping, pre-load the fork in the same way. Continue to model by eating together",
            "stage_2_p3_link": "",
            "stage_3_name": "Self-feeding with confidence",
            "stage_3_age": "24 months - 5 years",
            "stage_3_heading": "Full Independence",
            "stage_3_body": "The desire for independence is at its fiercest right now — and your toddlers hands are starting to match it. The right tools turn that determination into genuine skill faster than you'd think.",
            "stage_3_bullet_1": "Using a fork and spoon with confidence",
            "stage_3_bullet_2": "Interested in cutting their own food",
            "stage_3_bullet_3": "Eating with two utentils at once",
            "stage_3_bullet_4": "Sitting at the table independently",
            "stage_3_p1_img": "shopify://shop_images/7_3ade6bb2-0acd-44a5-8fa6-2133444332c0.png",
            "stage_3_p1_name": "Toddler Knife",
            "stage_3_p1_b1": "Handle sits in the palm supporting your toddlers developing wrist muscles and allowing them to push down through all food",
            "stage_3_p1_b2": "Naturally encourages the correct grip needed for adult knives",
            "stage_3_p1_link": "shopify://products/childrens-spoon-fork-knife-set",
            "stage_3_p2_img": "shopify://shop_images/8_95446b71-57cb-4097-9bb6-aef4b4b94eba.png",
            "stage_3_p2_name": "2-in-1 Bowl and Plate (suction removed)",
            "stage_3_p2_b1": "Suction rim is easy to remove and reattach helping support your child as they transition from suction to non-suction.",
            "stage_3_p2_b2": "To reattach suction rim, simply pinch the suction rim and tableware together and run your thumb round the inside edge.",
            "stage_3_p2_link": "",
            "stage_3_p3_img": "shopify://shop_images/9_293c2f46-0d45-4505-b97e-2b6f80aafa40.png",
            "stage_3_p3_name": "Easy to Introduce",
            "stage_3_p3_b1": "Hold your hand over your toddlers hand and push down through soft foods initially (like banana) then let them practice.",
            "stage_3_p3_b2": "Encourage the use of the knife at every mealtime so they can practice. Your toddler can now get involved in food preparation and cooking too!",
            "stage_3_p3_link": "shopify://products/toddler-knife"
          }
        },
