          }
        },
        "image_x9LALy": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Registered-Nutritionist_jpg.webp",
            "media_width": 50,
            "media_position": "start",
            "text_position": "place-self-start text-start",
            "icon": "none",
            "icon_width": 48,
            "subheading": "Registered Nutritionist / Founder of I Love Greens / co-founder of ‘Happy Tums’",
            "title": "Nicola Ragon-Paxton",
            "content": "<p>“doddl cutlery is perfectly designed for a toddler’s hand and the short handle means it’s easier to control. But the best bit for me are the metal heads which make it easy for baby to scoop and fork food compared to chunky plastic heads which can be frustrating for young ones. One of my recommended weaning essentials!”</p>",
            "link_text": "Learn more about Nicola's work here!",
            "link_url": "https://www.linkedin.com/in/nicola-ragon-paxton/",
            "background": "#ffffff",
            "background_gradient": "",
            "text_color": "#212529",
            "text_gradient": "",
