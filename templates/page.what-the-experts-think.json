        "image_UL7WPa": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Penelope_Henderson.png",
            "media_width": 50,
            "media_position": "end",
            "text_position": "place-self-start-end text-end",
            "icon": "none",
            "icon_width": 48,
            "subheading": "Children's Nutritionist",
            "title": "Penelope Henderson",
            "content": "<p>\"I love the unique design of doddl cutlery. The short, moulded handles fit perfectly in little hands and have a soft middle for a comfortable grip. I also love how they support motor skill development like dexterity and coordination, making self-feeding easier. The toddler knife helps build cutting skills safely, giving parents peace of mind. With easy-to-use cutlery, little ones can explore a wide range of foods and gain early exposure to new tastes and textures. I’d definitely recommend these to parents.\"</p>",
            "link_text": "Nutrition 2 Nourish Flourish",
            "link_url": "https://nutrition2nourishflourish.com/",
            "background": "#ffffff",
            "background_gradient": "",
            "text_color": "#000000",
            "text_gradient": "",
